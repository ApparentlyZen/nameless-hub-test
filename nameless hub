task.spawn(function()
    while true do
        task.wait(15)
        local list = GetPlayerList()
        pcall(function() if SALockDrop   then SALockDrop:SetValues(list)   end end)
        pcall(function() if SoruLockDrop then SoruLockDrop:SetValues(list) end end)
    end
end)

