local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local RS = game:GetService("ReplicatedStorage")
local lp = Players.LocalPlayer
local cam = workspace.CurrentCamera
local Mouse = lp:GetMouse()
local commE = RS:FindFirstChild("Remotes") and RS.Remotes:FindFirstChild("CommE")
local MouseMod = RS:FindFirstChild("Mouse")

-- ================================================
--  SILENT AIM MODULE (Z/X/C/V/F only, M1 excluded)
-- ================================================
local SA = (function()
    local M = {}
    
    local UIS = UserInputService
    local RnSvc = RunService

    -- STATE
    local SAPlayersOn    = false
    local SANPCsOn       = false
    local WantsPlayers   = false
    local WantsNPCs      = false
    local PredOn         = false
    local HighlightOn    = false
    local ZSkillsOn      = false
    local maxRange       = 1000
    local predAmt        = 0.1
    local Selected       = nil
    local zSkillActive   = false  -- SA actif seulement pendant Z/X/C/V/F

    local renderConn   = nil
    local curHighlight = nil
    local curTgtType   = nil
    local PlPos        = nil
    local NPCPos       = nil

    local godZ       = false
    local aimOn      = false
    local aimTarget  = nil
    local aimRender  = nil
    local aimTimeout = nil
    local infoOn     = false
    local infoConn   = nil

    local curTool    = nil
    local lastTool   = nil
    local sharkZ     = false
    local doughV     = false
    local cursedZ    = false
    local rightTouch = false
    local dmgConn    = nil
    local charConns  = {}

    local MiniPCreated = false
    local MiniNCreated = false
    local MiniPGui, MiniNGui = nil, nil
    local MiniPState, MiniNState = nil, nil

    -- Target Info UI
    local sg = Instance.new("ScreenGui")
    sg.Name = "NamelessTargetUI" sg.ResetOnSpawn = false sg.Parent = lp:WaitForChild("PlayerGui")
    local tf = Instance.new("Frame")
    tf.Size = UDim2.new(0.25,0,0.08,0) tf.Position = UDim2.new(0.5,0,0.05,0)
    tf.AnchorPoint = Vector2.new(0.5,0) tf.BackgroundTransparency = 1 tf.Visible = false tf.Parent = sg
    local tnl = Instance.new("TextLabel")
    tnl.Size = UDim2.new(1,0,0.5,0) tnl.BackgroundTransparency = 1 tnl.TextScaled = true
    tnl.Font = Enum.Font.GothamBold tnl.TextColor3 = Color3.new(1,1,1) tnl.Parent = tf
    local hpbg = Instance.new("Frame")
    hpbg.Size = UDim2.new(1,0,0.35,0) hpbg.Position = UDim2.new(0,0,0.55,0)
    hpbg.BackgroundColor3 = Color3.fromRGB(40,40,40) hpbg.BorderSizePixel = 0 hpbg.Parent = tf
    local hpf = Instance.new("Frame")
    hpf.Size = UDim2.new(1,0,1,0) hpf.BackgroundColor3 = Color3.fromRGB(0,255,0)
    hpf.BorderSizePixel = 0 hpf.Parent = hpbg

    -- HELPERS
    local function getHRP(m) return m and m:FindFirstChild("HumanoidRootPart") end

    local function clearConns()
        for _, c in ipairs(charConns) do pcall(function() c:Disconnect() end) end
        charConns = {}
        if dmgConn then pcall(function() dmgConn:Disconnect() end) dmgConn = nil end
        if aimRender then pcall(function() aimRender:Disconnect() end) aimRender = nil end
        if aimTimeout then pcall(function() task.cancel(aimTimeout) end) aimTimeout = nil end
    end

    local function isAlly(tp)
        local g = lp:FindFirstChild("PlayerGui") if not g then return false end
        local sf = g:FindFirstChild("Main") and g.Main:FindFirstChild("Allies")
            and g.Main.Allies:FindFirstChild("Container")
            and g.Main.Allies.Container:FindFirstChild("Allies")
            and g.Main.Allies.Container.Allies:FindFirstChild("ScrollingFrame")
        if sf then
            for _, f in pairs(sf:GetDescendants()) do
                if f:IsA("ImageButton") and f.Name == tp.Name then return true end
            end
        end
        return false
    end

    local function isEnemy(tp)
        if not tp or tp == lp then return false end
        local mt, tt = lp.Team, tp.Team
        if mt and tt then
            if mt.Name == "Pirates" and tt.Name == "Marines" then return true end
            if mt.Name == "Marines" and tt.Name == "Pirates" then return true end
            if mt.Name == "Pirates" and tt.Name == "Pirates" then return not isAlly(tp) end
            if mt.Name == "Marines" and tt.Name == "Marines" then return false end
        end
        return true
    end

    local function predicted(hrp)
        if not hrp then return nil end
        local hum = hrp.Parent:FindFirstChildOfClass("Humanoid")
        if not PredOn or not hum or hum.WalkSpeed < 5 then return hrp.Position end
        return hrp.Position + hrp.Velocity * predAmt
    end

    local function closestPlayer(lpHRP)
        if not lpHRP then return nil end
        if Selected and Selected.Character and getHRP(Selected.Character) then return Selected end
        local best, bd = nil, math.huge
        for _, pl in ipairs(Players:GetPlayers()) do
            if pl ~= lp and isEnemy(pl) and pl.Character then
                local hum = pl.Character:FindFirstChildOfClass("Humanoid")
                local hrp = getHRP(pl.Character)
                if hum and hum.Health > 0 and hrp then
                    local d = (hrp.Position - lpHRP.Position).Magnitude
                    if d <= maxRange and d < bd then bd = d best = pl end
                end
            end
        end
        return best
    end

    local function closestNPC(lpHRP)
        if not lpHRP then return nil end
        local ef = workspace:FindFirstChild("Enemies") if not ef then return nil end
        local best, bd = nil, math.huge
        for _, npc in ipairs(ef:GetChildren()) do
            if npc:IsA("Model") then
                local hum = npc:FindFirstChildOfClass("Humanoid")
                local hrp = getHRP(npc)
                if hum and hum.Health > 0 and hrp then
                    local d = (hrp.Position - lpHRP.Position).Magnitude
                    if d <= maxRange and d < bd then bd = d best = npc end
                end
            end
        end
        return best
    end

    -- HIGHLIGHT
    local function clearHL()
        if curHighlight then pcall(function() curHighlight:Destroy() end) curHighlight = nil end
        curTgtType = nil
    end

    local function applyHL(model, ttype)
        if not HighlightOn or not model then return end
        if curHighlight and curHighlight.Adornee == model then return end
        clearHL()
        local h = Instance.new("Highlight")
        h.FillTransparency = 0.5
        h.OutlineTransparency = 0
        h.FillColor = ttype == "Player" and Color3.fromRGB(255,50,50) or Color3.fromRGB(255,165,0)
        h.OutlineColor = Color3.new(1,1,1)
        h.Adornee = model h.Parent = model
        curHighlight = h curTgtType = ttype
    end

    -- RENDER LOOP
    local function stopLoop()
        if renderConn then pcall(function() renderConn:Disconnect() end) renderConn = nil end
        PlPos = nil NPCPos = nil clearHL()
    end

    local function startLoop()
        if renderConn then return end
        renderConn = RnSvc.Heartbeat:Connect(function()
            if not SAPlayersOn and not SANPCsOn then return end
            if not zSkillActive then return end

            local char = lp.Character
            local lpHRP = char and getHRP(char)
            if not lpHRP then return end

            if SAPlayersOn then
                local t = closestPlayer(lpHRP)
                if t and t.Character then
                    local hrp = getHRP(t.Character)
                    if hrp then PlPos = predicted(hrp) applyHL(t.Character,"Player") end
                else PlPos = nil if curTgtType=="Player" then clearHL() end end
            else PlPos = nil end

            if SANPCsOn and not PlPos then
                local n = closestNPC(lpHRP)
                if n then
                    local hrp = getHRP(n)
                    if hrp then NPCPos = predicted(hrp) applyHL(n,"NPC") end
                else NPCPos = nil if curTgtType=="NPC" then clearHL() end end
            else if not SAPlayersOn then NPCPos = nil end end

            local tgt = PlPos and CFrame.new(PlPos) or NPCPos and CFrame.new(NPCPos)
            if tgt and MouseMod then
                local ok, md = pcall(require, MouseMod)
                if ok and type(md)=="table" then md.Hit = tgt md.Target = nil end
            end
        end)
    end

    -- VSKILL pause/restore
    local function pauseSA()   SAPlayersOn = false SANPCsOn = false end
    local function restoreSA()
        SAPlayersOn = WantsPlayers SANPCsOn = WantsNPCs
    end

    local function isVSkill()
        return (curTool and curTool.Name == "Shark Anchor" and sharkZ)
            or (lastTool == "Dough-Dough" and doughV)
            or (curTool and curTool.Name == "Cursed Dual Katana" and cursedZ)
    end

    -- ZSKILL aimlock
    local function getNearestEnemy(d)
        local char = lp.Character local hrp = char and getHRP(char) if not hrp then return nil end
        local best, bd = nil, d or 1000
        for _, pl in ipairs(Players:GetPlayers()) do
            if pl ~= lp and isEnemy(pl) and pl.Character then
                local ohp = getHRP(pl.Character)
                local hum = pl.Character:FindFirstChildOfClass("Humanoid")
                if ohp and hum and hum.Health > 0 then
                    local dist = (ohp.Position - hrp.Position).Magnitude
                    if dist < bd then bd = dist best = pl.Character end
                end
            end
        end
        return best
    end

    local function stopAimlock()
        if not aimOn then return end
        aimOn = false aimTarget = nil godZ = false
        if aimRender then pcall(function() aimRender:Disconnect() end) aimRender = nil end
        if aimTimeout then pcall(function() task.cancel(aimTimeout) end) aimTimeout = nil end
    end

    local function startAimlock()
        if not ZSkillsOn or aimOn then return end
        aimTarget = getNearestEnemy(1000) if not aimTarget then return end
        aimOn = true
        aimRender = RnSvc.RenderStepped:Connect(function()
            if not ZSkillsOn then stopAimlock() return end
            if aimOn and aimTarget and getHRP(aimTarget) then
                cam.CFrame = CFrame.lookAt(cam.CFrame.Position, getHRP(aimTarget).Position)
            else stopAimlock() end
        end)
        aimTimeout = task.delay(1, function() if aimOn then stopAimlock() end end)
    end

    -- DAMAGE WATCH
    local function watchDMG()
        if dmgConn then pcall(function() dmgConn:Disconnect() end) dmgConn = nil end
        task.spawn(function()
            while true do
                local gui = lp.PlayerGui:FindFirstChild("Main")
                if not gui then task.wait(1) continue end
                local dc = gui:FindFirstChild("DmgCounter")
                if not dc then task.wait(1) continue end
                local lbl = dc:FindFirstChild("Text")
                if not lbl then task.wait(1) continue end
                dmgConn = lbl:GetPropertyChangedSignal("Text"):Connect(function()
                    local dmg = tonumber(lbl.Text) or 0
                    if dmg > 0 then
                        if isVSkill() and rightTouch then pauseSA() end
                        if aimOn then stopAimlock() end
                    elseif not rightTouch then
                        restoreSA()
                    end
                end)
                table.insert(charConns, dmgConn) break
            end
        end)
    end

    -- TOUCH (pour VSkills)
    UIS.TouchStarted:Connect(function(t)
        if not cam then return end
        if t.Position.X > cam.ViewportSize.X / 2 then
            rightTouch = true
            if isVSkill() then pauseSA() end
        end
    end)

    UIS.TouchEnded:Connect(function(t)
        if not cam then return end
        if t.Position.X > cam.ViewportSize.X / 2 then
            rightTouch = false
            restoreSA()
            sharkZ = false doughV = false cursedZ = false
            if curTool and curTool.Name == "Godhuman" and godZ and not aimOn then
                startAimlock()
            end
        end
    end)

    -- TOOL HOOK
    local function hookTool(tool)
        if not tool then return end
        curTool = tool lastTool = tool.Name
        table.insert(charConns, tool.AncestryChanged:Connect(function(_, parent)
            if not parent then
                curTool = nil lastTool = nil
                sharkZ = false doughV = false cursedZ = false
                godZ = false aimOn = false
                rightTouch = false restoreSA()
            end
        end))
    end

    -- NAMECALL HOOK (Z/X/C/V/F)
    if not getgenv().NamelessHooked then
        getgenv().NamelessHooked = true
        local old
        old = hookmetamethod(game, "__namecall", function(self, ...)
            local method = getnamecallmethod()
            local args = { ... }
            if method == "InvokeServer" or method == "FireServer" then
                local a1 = args[1]
                if typeof(a1) == "string" then
                    local up = a1:upper()
                    if up == "Z" or up == "X" or up == "C" or up == "V" or up == "F" then
                        zSkillActive = true
                        if ZSkillsOn and (PlPos or NPCPos) then
                            local targetPos = PlPos or NPCPos
                            task.delay(1, function() zSkillActive = false end)
                            return old(self, up, targetPos, ...)
                        end
                        task.delay(1, function() zSkillActive = false end)
                    end
                    if up == "Z" and curTool then
                        if curTool.Name == "Godhuman" then godZ = true end
                        if curTool.Name == "Shark Anchor" then sharkZ = true end
                        if curTool.Name == "Cursed Dual Katana" then cursedZ = true end
                    end
                    if up == "V" and lastTool == "Dough-Dough" then doughV = true end
                end
            end
            return old(self, ...)
        end)
    end

    -- MINI TOGGLES
    local function createMini(name, pos, stateRef, setter)
        local pg = lp:WaitForChild("PlayerGui")
        if pg:FindFirstChild(name.."NML") then pg[name.."NML"]:Destroy() end
        local sg2 = Instance.new("ScreenGui") sg2.Name = name.."NML" sg2.ResetOnSpawn = false sg2.Parent = pg
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(0,70,0,40) btn.Position = pos btn.TextScaled = true
        btn.TextColor3 = Color3.new(1,1,1) btn.BackgroundColor3 = Color3.fromRGB(30,30,30)
        btn.BorderSizePixel = 0 btn.Parent = sg2
        Instance.new("UICorner", btn).CornerRadius = UDim.new(0,8)
        local grad = Instance.new("UIGradient") grad.Rotation = 45 grad.Parent = btn
        local function refresh(s)
            btn.Text = name..(s and " ON" or " OFF")
            grad.Color = ColorSequence.new{
                ColorSequenceKeypoint.new(0, s and Color3.fromRGB(50,200,50) or Color3.fromRGB(255,100,50)),
                ColorSequenceKeypoint.new(1, s and Color3.fromRGB(50,255,50) or Color3.fromRGB(255,200,50))
            }
        end
        btn.MouseButton1Click:Connect(function()
            stateRef.value = not stateRef.value setter(stateRef.value) refresh(stateRef.value)
        end)
        local drag, ds, sp = false, nil, nil
        btn.InputBegan:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.Touch or i.UserInputType == Enum.UserInputType.MouseButton1 then
                drag = true ds = i.Position sp = btn.Position
                i.Changed:Connect(function() if i.UserInputState == Enum.UserInputState.End then drag = false end end)
            end
        end)
        btn.InputChanged:Connect(function(i)
            if drag and (i.UserInputType == Enum.UserInputType.Touch or i.UserInputType == Enum.UserInputType.MouseMovement) then
                local d = i.Position - ds
                btn.Position = UDim2.new(0,
                    math.clamp(sp.X.Offset+d.X, 0, cam.ViewportSize.X-btn.AbsoluteSize.X),
                    0,
                    math.clamp(sp.Y.Offset+d.Y, 0, cam.ViewportSize.Y-btn.AbsoluteSize.Y))
            end
        end)
        refresh(stateRef.value) return sg2
    end

    local function updateMini()
        SAPlayersOn = MiniPState and MiniPState.value or false
        SANPCsOn = MiniNState and MiniNState.value or false
        WantsPlayers = SAPlayersOn WantsNPCs = SANPCsOn
        if SAPlayersOn or SANPCsOn then startLoop() else stopLoop() clearHL() end
    end

    -- CHARACTER ADDED
    local function onCharAdded(char)
        clearConns()
        sharkZ=false doughV=false cursedZ=false
        godZ=false aimOn=false rightTouch=false zSkillActive=false
        restoreSA()
        for _, c in ipairs(char:GetChildren()) do if c:IsA("Tool") then hookTool(c) end end
        table.insert(charConns, char.ChildAdded:Connect(function(c)
            if c:IsA("Tool") then hookTool(c) end
        end))
        table.insert(charConns, char.ChildRemoved:Connect(function(c)
            if c == curTool then
                curTool=nil lastTool=nil
                sharkZ=false doughV=false cursedZ=false
                godZ=false aimOn=false restoreSA()
            end
        end))
        watchDMG()
    end

    lp.CharacterAdded:Connect(onCharAdded)
    if lp.Character then onCharAdded(lp.Character) end

    -- PUBLIC API
    function M:SetPlayerSilentAim(state)
        WantsPlayers = state SAPlayersOn = state
        if state then startLoop() else if not SANPCsOn then stopLoop() end stopAimlock() end
    end
    function M:SetNPCSilentAim(state)
        WantsNPCs = state SANPCsOn = state
        if state then startLoop() else if not SAPlayersOn then stopLoop() end end
    end
    function M:SetPrediction(state) PredOn = state end
    function M:SetPredictionAmount(n) if type(n)=="number" then predAmt = n end end
    function M:SetDistanceLimit(n) if type(n)=="number" then maxRange = n end end
    function M:SetHighlight(state) HighlightOn = state if not state then clearHL() end end
    function M:SetZSkills(state) ZSkillsOn = state end
    function M:SetSelectedPlayer(name)
        if not name or name=="" then Selected=nil return end
        local f = Players:FindFirstChild(name) if f then Selected=f end
    end
    function M:SetInfo(state)
        infoOn = state
        if state then
            if not infoConn then
                infoConn = RnSvc.RenderStepped:Connect(function()
                    local t = getNearestEnemy(1000)
                    if t and t:FindFirstChildOfClass("Humanoid") then
                        local h = t:FindFirstChildOfClass("Humanoid")
                        tnl.Text = t.Name
                        hpf.Size = UDim2.new(math.clamp(h.Health/h.MaxHealth,0,1),0,1,0)
                        hpbg.Visible=true hpf.Visible=true tf.Visible=true
                    else tnl.Text="No target" hpbg.Visible=false hpf.Visible=false tf.Visible=true end
                end)
            end
        else
            if infoConn then infoConn:Disconnect() infoConn=nil end
            tf.Visible=false
        end
    end
    function M:SetMiniTogglePlayerSilentAim(state)
        if not MiniPCreated and state then
            MiniPState = { value = SAPlayersOn }
            MiniPGui = createMini("Player", UDim2.new(0,10,0,90), MiniPState, function(v)
                MiniPState.value = v updateMini()
            end)
            MiniPCreated = true
        elseif MiniPCreated and MiniPGui then MiniPGui.Enabled = state end
    end
    function M:SetMiniToggleNpcSilentAim(state)
        if not MiniNCreated and state then
            MiniNState = { value = SANPCsOn }
            MiniNGui = createMini("NPC", UDim2.new(0,10,0,50), MiniNState, function(v)
                MiniNState.value = v updateMini()
            end)
            MiniNCreated = true
        elseif MiniNCreated and MiniNGui then MiniNGui.Enabled = state end
    end

    return M
end)()

-- ================================================
--  SORU AUTO AIM MODULE
-- ================================================
local SoruAutoAim = (function()
    local Enabled = false
    local SelectedPlayer = nil
    local CurrentTarget = nil
    local function isEnemy(tp)
        if not tp or tp == lp then return false end
        local mt, tt = lp.Team, tp.Team
        if mt and tt then
            if mt.Name == "Pirates" and tt.Name == "Marines" then return true end
            if mt.Name == "Marines" and tt.Name == "Pirates" then return true end
            if mt.Name == "Pirates" and tt.Name == "Pirates" then
                local g = lp:FindFirstChild("PlayerGui")
                if g and g:FindFirstChild("Main") and g.Main:FindFirstChild("Allies") then
                    local allies = g.Main.Allies:FindFirstChild("Container")
                    if allies then
                        local scroll = allies:FindFirstChild("Allies") and allies.Allies:FindFirstChild("ScrollingFrame")
                        if scroll then
                            for _, btn in pairs(scroll:GetDescendants()) do
                                if btn:IsA("ImageButton") and btn.Name == tp.Name then return false end
                            end
                        end
                    end
                end
                return true
            end
            if mt.Name == "Marines" and tt.Name == "Marines" then return false end
        end
        return true
    end

    local function getClosestEnemy()
        local myHRP = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
        if not myHRP then return nil end
        local closest, closestDist = nil, math.huge
        for _, pl in ipairs(Players:GetPlayers()) do
            if pl ~= lp and isEnemy(pl) and pl.Character then
                local hrp = pl.Character:FindFirstChild("HumanoidRootPart")
                local hum = pl.Character:FindFirstChildOfClass("Humanoid")
                if hrp and hum and hum.Health > 0 then
                    local dist = (hrp.Position - myHRP.Position).Magnitude
                    if dist < closestDist then
                        closestDist = dist
                        closest = pl.Character.HumanoidRootPart
                    end
                end
            end
        end
        return closest
    end

    -- Hook Mouse.Hit et Mouse.Target
    local oldIndex
    local mt = getrawmetatable(game)
    local oldMT = mt.__index
    setreadonly(mt, false)
    mt.__index = newcclosure(function(t, k)
        if t == Mouse and Enabled then
            local target = nil
            if SelectedPlayer and SelectedPlayer.Character and SelectedPlayer.Character:FindFirstChild("HumanoidRootPart") then
                target = SelectedPlayer.Character.HumanoidRootPart
            else
                target = getClosestEnemy()
            end
            if target then
                if k == "Hit" then return target.CFrame end
                if k == "Target" then return target end
            end
        end
        return oldMT(t, k)
    end)
    setreadonly(mt, true)

    -- Hook InvokeServer pour rediriger les attaques qui utilisent un Vector3 (ex: Soru)
    local oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
        local method = getnamecallmethod()
        local args = {...}
        if (method == "InvokeServer" or method == "FireServer") and Enabled then
            if self == commE and args[1] == "Soru" then
                -- On redirige la position vers la cible
                local target = nil
                if SelectedPlayer and SelectedPlayer.Character then
                    target = SelectedPlayer.Character:FindFirstChild("HumanoidRootPart")
                else
                    target = getClosestEnemy()
                end
                if target then
                    -- Modifier les arguments : la position est souvent args[2] (Vector3)
                    -- Ici on laisse passer normalement, mais on peut aussi rediriger
                    return oldNamecall(self, ...)
                end
            end
        end
        return oldNamecall(self, ...)
    end)

    return {
        setEnabled = function(v) Enabled = v end,
        setSelectedPlayer = function(name)
            if not name or name == "None" then SelectedPlayer = nil
            else SelectedPlayer = Players:FindFirstChild(name) end
        end,
        isEnabled = function() return Enabled end
    }
end)()

-- ================================================
--  GLITCH MODULES (Sanguine & Diamond)
-- ================================================
local Glitch = (function()
    local multiEnabled = false
    local multiPower = 400
    local multiDuration = 0.9
    local multiCharging = false
    local multiChargeStart = 0

    local diamondEnabled = false
    local diamondPower = 400
    local diamondDuration = 0.9
    local diamondRequiredCharge = 1.0
    local diamondCharging = false
    local diamondChargeStart = 0

    local function MegaBoost()
        local char = lp.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        local hum = char and char:FindFirstChildOfClass("Humanoid")
        if not hrp or not hum then return end
        local targetPos = Mouse.Hit.p
        local direction = (targetPos - hrp.Position).Unit
        hum.PlatformStand = true
        local att = Instance.new("Attachment", hrp)
        local lv = Instance.new("LinearVelocity", hrp)
        lv.MaxForce = 9999999
        lv.VelocityConstraintMode = Enum.VelocityConstraintMode.Vector
        lv.VectorVelocity = direction * multiPower
        lv.Attachment0 = att
        task.wait(multiDuration)
        if lv then lv:Destroy() end
        if att then att:Destroy() end
        hum.PlatformStand = false
    end

    local function DiamondBoost()
        local char = lp.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        local hum = char and char:FindFirstChildOfClass("Humanoid")
        if not hrp or not hum then return end
        local direction = (Mouse.Hit.p - hrp.Position).Unit
        hum.PlatformStand = true
        local att = Instance.new("Attachment", hrp)
        local lv = Instance.new("LinearVelocity", hrp)
        lv.MaxForce = 9999999
        lv.VelocityConstraintMode = Enum.VelocityConstraintMode.Vector
        lv.VectorVelocity = direction * diamondPower
        lv.Attachment0 = att
        task.wait(diamondDuration)
        if lv then lv:Destroy() end
        if att then att:Destroy() end
        hum.PlatformStand = false
    end

    RunService.Heartbeat:Connect(function()
        if multiEnabled then
            local char = lp.Character
            local hum = char and char:FindFirstChildOfClass("Humanoid")
            if hum then
                local isGhoulCharging = false
                for _, anim in pairs(hum:GetPlayingAnimationTracks()) do
                    if anim.Animation.AnimationId:find("14418367908") or anim.Name == "GhoulZCharge" then
                        isGhoulCharging = true break
                    end
                end
                if isGhoulCharging then
                    if not multiCharging then multiCharging = true multiChargeStart = tick() end
                else
                    if multiCharging then
                        if (tick() - multiChargeStart) >= 2.0 then task.spawn(MegaBoost) end
                        multiCharging = false
                    end
                end
            end
        end

        if diamondEnabled then
            local char = lp.Character
            local hum = char and char:FindFirstChildOfClass("Humanoid")
            if hum then
                local isCharging = false
                for _, anim in pairs(hum:GetPlayingAnimationTracks()) do
                    if anim.Animation.AnimationId:find("14414815375") then
                        isCharging = true break
                    end
                end
                if isCharging then
                    if not diamondCharging then diamondCharging = true diamondChargeStart = tick() end
                else
                    if diamondCharging then
                        if (tick() - diamondChargeStart) >= diamondRequiredCharge then
                            task.spawn(DiamondBoost)
                        end
                        diamondCharging = false
                    end
                end
            end
        end
    end)

    return {
        setSanguine = function(v) multiEnabled = v end,
        setSanguinePower = function(v) multiPower = v end,
        setSanguineDuration = function(v) multiDuration = v end,
        setDiamond = function(v) diamondEnabled = v end,
        setDiamondPower = function(v) diamondPower = v end,
        setDiamondDuration = function(v) diamondDuration = v end,
        setDiamondCharge = function(v) diamondRequiredCharge = v end
    }
end)()

-- ================================================
--  ESP MODULE (Players + NPCs)
-- ================================================
local ESP = (function()
    local ESPEnabled = false
    local ESPNPCEnabled = false

    -- Players toggles
    local ESPBox = true
    local ESPCornerBox = false
    local ESPFilledBox = false
    local ESPLines = true
    local ESPName = true
    local ESPDistance = true
    local ESPHealthBar = true
    local ESPHealthNum = false
    local ESPWeapon = false
    local ESPTeam = false
    local ESPBounty = false
    local ESPSkeleton = false
    local ESPHeadDot = false
    local ESPOffScreen = false
    local ESPChams = false

    -- NPC toggles
    local ESPNPCBox = true
    local ESPNPCName = true
    local ESPNPCDist = true
    local ESPNPCHp = true
    local ESPNPCChams = false

    local espObjects = {}
    local espConnection = nil
    local chamsObjects = {}

    local function worldToViewport(pos)
        if not cam then return nil, false end
        local screenPos, onScreen = cam:WorldToViewportPoint(pos)
        return Vector2.new(screenPos.X, screenPos.Y), onScreen, screenPos.Z
    end

    local function getCharBounds(char)
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then return nil end
        local head = char:FindFirstChild("Head")
        local topPos = head and head.Position + Vector3.new(0, head.Size.Y/2 + 0.2, 0) or hrp.Position + Vector3.new(0, 3, 0)
        local botPos = hrp.Position - Vector3.new(0, 3, 0)

        local topScreen, topOn, topZ = worldToViewport(topPos)
        local botScreen, botOn = worldToViewport(botPos)

        if not topOn and not botOn then return nil end

        local h = math.abs(topScreen.Y - botScreen.Y)
        local w = h * 0.6
        local cx = topScreen.X

        return { top = topScreen, bot = botScreen, cx = cx, w = w, h = h, depth = topZ, onScreen = topOn or botOn }
    end

    local function createDrawings(key)
        local d = {}
        d.boxTop = Drawing.new("Line")
        d.boxBot = Drawing.new("Line")
        d.boxLeft = Drawing.new("Line")
        d.boxRight = Drawing.new("Line")
        d.cTL1 = Drawing.new("Line") d.cTL2 = Drawing.new("Line")
        d.cTR1 = Drawing.new("Line") d.cTR2 = Drawing.new("Line")
        d.cBL1 = Drawing.new("Line") d.cBL2 = Drawing.new("Line")
        d.cBR1 = Drawing.new("Line") d.cBR2 = Drawing.new("Line")
        d.filled = Drawing.new("Square")
        d.line = Drawing.new("Line")
        d.name = Drawing.new("Text")
        d.dist = Drawing.new("Text")
        d.hpBg = Drawing.new("Line")
        d.hpFill = Drawing.new("Line")
        d.hpNum = Drawing.new("Text")
        d.weapon = Drawing.new("Text")
        d.team = Drawing.new("Text")
        d.bounty = Drawing.new("Text")
        d.headDot = Drawing.new("Circle")
        d.sk = {}
        for i = 1, 12 do d.sk[i] = Drawing.new("Line") end
        d.arrow = Drawing.new("Triangle")
        for _, obj in pairs(d) do if type(obj) ~= "table" then obj.Visible = false end end
        for _, obj in ipairs(d.sk) do obj.Visible = false end
        for _, b in ipairs({d.boxTop,d.boxBot,d.boxLeft,d.boxRight,d.cTL1,d.cTL2,d.cTR1,d.cTR2,d.cBL1,d.cBL2,d.cBR1,d.cBR2}) do b.Thickness = 1 end
        d.line.Thickness = 1
        d.hpBg.Thickness = 4 d.hpFill.Thickness = 4
        for _, s in ipairs(d.sk) do s.Thickness = 1 s.Transparency = 0.3 end
        for _, t in ipairs({d.name, d.dist, d.hpNum, d.weapon, d.team, d.bounty}) do t.Size = 12 t.Center = true t.Outline = true t.Font = 2 end
        d.name.Size = 13
        d.dist.Color = Color3.fromRGB(200,200,200)
        d.hpNum.Color = Color3.fromRGB(255,255,255)
        d.weapon.Color = Color3.fromRGB(255,220,100)
        d.team.Color = Color3.fromRGB(100,200,255)
        d.bounty.Color = Color3.fromRGB(255,180,50)
        d.headDot.Radius = 4 d.headDot.Thickness = 1 d.headDot.Filled = true
        d.filled.Transparency = 0.7
        d.arrow.Thickness = 1 d.arrow.Filled = true
        espObjects[key] = d
        return d
    end

    local function hideDrawings(d)
        if not d then return end
        for _, obj in pairs(d) do obj.Visible = false end
    end

    local function removeDrawings(key)
        local d = espObjects[key]
        if d then
            for _, obj in pairs(d) do pcall(function() obj:Remove() end) end
            espObjects[key] = nil
        end
    end

    local function applyChams(char, col)
        local key = tostring(char)
        if chamsObjects[key] then return end
        chamsObjects[key] = {}
        for _, part in ipairs(char:GetDescendants()) do
            if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
                local orig = part.Color
                part.Color = col
                table.insert(chamsObjects[key], {part=part, orig=orig})
            end
        end
    end

    local function removeChams(char)
        if not char then return end
        local key = tostring(char)
        if not chamsObjects[key] then return end
        for _, data in ipairs(chamsObjects[key]) do
            pcall(function() data.part.Color = data.orig end)
        end
        chamsObjects[key] = nil
    end

    local skBones = {
        {"Head","UpperTorso"},{"UpperTorso","LowerTorso"},
        {"UpperTorso","RightUpperArm"},{"RightUpperArm","RightLowerArm"},{"RightLowerArm","RightHand"},
        {"UpperTorso","LeftUpperArm"},{"LeftUpperArm","LeftLowerArm"},{"LeftLowerArm","LeftHand"},
        {"LowerTorso","RightUpperLeg"},{"RightUpperLeg","RightLowerLeg"},
        {"LowerTorso","LeftUpperLeg"},{"LeftUpperLeg","LeftLowerLeg"},
    }

    local function updateESP(target, key, isNPC)
        local char = isNPC and target or (target.Character)
        if not char then hideDrawings(espObjects[key]) return end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hrp or not hum or hum.Health <= 0 then hideDrawings(espObjects[key]) return end

        local bounds = getCharBounds(char)
        local d = espObjects[key] or createDrawings(key)
        local col = isNPC and Color3.fromRGB(255,165,0) or Color3.fromRGB(255,50,50)
        if not isNPC then
            local pl = Players:FindFirstChild(char.Name)
            if pl and not isEnemy(pl) then col = Color3.fromRGB(50,255,50) end
        end

        local myChar = lp.Character
        local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")
        local dist = myHRP and math.floor((hrp.Position - myHRP.Position).Magnitude) or 0

        local screenPos2, onScreen2 = worldToViewport(hrp.Position)
        if not onScreen2 and ESPOffScreen then
            local screenCenter = Vector2.new(cam.ViewportSize.X/2, cam.ViewportSize.Y/2)
            local dir = (screenPos2 - screenCenter).Unit
            local angle = math.atan2(dir.Y, dir.X)
            local arrowDist = 80
            local arrowPos = screenCenter + dir * arrowDist
            local sz = 10
            local p1 = arrowPos + Vector2.new(math.cos(angle)*sz, math.sin(angle)*sz)
            local p2 = arrowPos + Vector2.new(math.cos(angle+2.4)*sz*0.5, math.sin(angle+2.4)*sz*0.5)
            local p3 = arrowPos + Vector2.new(math.cos(angle-2.4)*sz*0.5, math.sin(angle-2.4)*sz*0.5)
            d.arrow.PointA = p1 d.arrow.PointB = p2 d.arrow.PointC = p3
            d.arrow.Color = col d.arrow.Visible = true
        else
            d.arrow.Visible = false
        end

        if not bounds or not bounds.onScreen then
            for k2, obj in pairs(d) do if k2 ~= "arrow" and k2 ~= "sk" then obj.Visible = false end end
            for _, s in ipairs(d.sk) do s.Visible = false end
            return
        end

        local cx = bounds.cx
        local w2 = bounds.w / 2
        local topY = bounds.top.Y
        local botY = bounds.bot.Y
        local left = cx - w2
        local right = cx + w2
        local cornerLen = bounds.w * 0.25

        d.boxTop.From=Vector2.new(left,topY) d.boxTop.To=Vector2.new(right,topY)
        d.boxBot.From=Vector2.new(left,botY) d.boxBot.To=Vector2.new(right,botY)
        d.boxLeft.From=Vector2.new(left,topY) d.boxLeft.To=Vector2.new(left,botY)
        d.boxRight.From=Vector2.new(right,topY) d.boxRight.To=Vector2.new(right,botY)
        for _, b in ipairs({d.boxTop,d.boxBot,d.boxLeft,d.boxRight}) do b.Color=col b.Visible=(isNPC and ESPNPCBox or ESPBox) end

        local cl = cornerLen
        d.cTL1.From=Vector2.new(left,topY) d.cTL1.To=Vector2.new(left+cl,topY)
        d.cTL2.From=Vector2.new(left,topY) d.cTL2.To=Vector2.new(left,topY+cl)
        d.cTR1.From=Vector2.new(right,topY) d.cTR1.To=Vector2.new(right-cl,topY)
        d.cTR2.From=Vector2.new(right,topY) d.cTR2.To=Vector2.new(right,topY+cl)
        d.cBL1.From=Vector2.new(left,botY) d.cBL1.To=Vector2.new(left+cl,botY)
        d.cBL2.From=Vector2.new(left,botY) d.cBL2.To=Vector2.new(left,botY-cl)
        d.cBR1.From=Vector2.new(right,botY) d.cBR1.To=Vector2.new(right-cl,botY)
        d.cBR2.From=Vector2.new(right,botY) d.cBR2.To=Vector2.new(right,botY-cl)
        for _, b in ipairs({d.cTL1,d.cTL2,d.cTR1,d.cTR2,d.cBL1,d.cBL2,d.cBR1,d.cBR2}) do b.Color=col b.Visible=ESPCornerBox end

        d.filled.Position = Vector2.new(left, topY)
        d.filled.Size = Vector2.new(bounds.w, bounds.h)
        d.filled.Color = col d.filled.Visible = ESPFilledBox

        local midTop = Vector2.new(cam.ViewportSize.X/2, 0)
        d.line.From=midTop d.line.To=Vector2.new(cx,topY) d.line.Color=col d.line.Visible=ESPLines

        local nameStr = isNPC and char.Name or char.Name
        d.name.Text=nameStr d.name.Position=Vector2.new(cx,topY-16) d.name.Color=col d.name.Visible=(isNPC and ESPNPCName or ESPName)

        d.dist.Text=dist.."m" d.dist.Position=Vector2.new(cx,botY+2) d.dist.Visible=(isNPC and ESPNPCDist or ESPDistance)

        local hpRatio = math.clamp(hum.Health/hum.MaxHealth,0,1)
        local barX = left - 6
        local hpColor = Color3.fromRGB(math.floor(255*(1-hpRatio)), math.floor(255*hpRatio), 0)
        d.hpBg.From=Vector2.new(barX,topY) d.hpBg.To=Vector2.new(barX,botY)
        d.hpBg.Color=Color3.fromRGB(40,40,40) d.hpBg.Visible=(isNPC and ESPNPCHp or ESPHealthBar)
        local fillY = botY-(botY-topY)*hpRatio
        d.hpFill.From=Vector2.new(barX,fillY) d.hpFill.To=Vector2.new(barX,botY)
        d.hpFill.Color=hpColor d.hpFill.Visible=(isNPC and ESPNPCHp or ESPHealthBar)

        d.hpNum.Text=math.floor(hum.Health).."/"..math.floor(hum.MaxHealth)
        d.hpNum.Position=Vector2.new(barX-2,topY+bounds.h/2-6)
        d.hpNum.Visible=ESPHealthNum

        local weaponStr = ""
        if ESPWeapon then
            for _, child in ipairs(char:GetChildren()) do
                if child:IsA("Tool") then weaponStr = child.Name break end
            end
        end
        d.weapon.Text=weaponStr d.weapon.Position=Vector2.new(cx,topY-28) d.weapon.Visible=ESPWeapon

        local teamStr = ""
        if not isNPC then
            local pl = Players:FindFirstChild(char.Name)
            teamStr = pl and pl.Team and pl.Team.Name or ""
        end
        d.team.Text=teamStr d.team.Position=Vector2.new(cx,botY+13) d.team.Visible=ESPTeam

        local bountyStr = ""
        if ESPBounty and not isNPC then
            local pl = Players:FindFirstChild(char.Name)
            if pl then
                local leaderstats = pl:FindFirstChild("leaderstats")
                local bounty = leaderstats and (leaderstats:FindFirstChild("Bounty") or leaderstats:FindFirstChild("Beli"))
                bountyStr = bounty and ("$"..tostring(bounty.Value)) or ""
            end
        end
        d.bounty.Text=bountyStr d.bounty.Position=Vector2.new(cx,botY+24) d.bounty.Visible=ESPBounty

        local head = char:FindFirstChild("Head")
        if head and ESPHeadDot then
            local headScreen, headOn = worldToViewport(head.Position)
            if headOn then
                d.headDot.Position=headScreen d.headDot.Color=col d.headDot.Visible=true
            else d.headDot.Visible=false end
        else d.headDot.Visible=false end

        for i, bone in ipairs(skBones) do
            local p1 = char:FindFirstChild(bone[1])
            local p2 = char:FindFirstChild(bone[2])
            local s = d.sk[i]
            if p1 and p2 and ESPSkeleton then
                local sp1, on1 = worldToViewport(p1.Position)
                local sp2, on2 = worldToViewport(p2.Position)
                if on1 or on2 then
                    s.From=sp1 s.To=sp2 s.Color=col s.Visible=true
                else s.Visible=false end
            else s.Visible=false end
        end

        if (isNPC and ESPNPCChams) or (not isNPC and ESPChams) then
            applyChams(char, col)
        else
            removeChams(char)
        end
    end

    local function startESP()
        if espConnection then return end
        espConnection = RunService.RenderStepped:Connect(function()
            local tracked = {}
            if ESPEnabled then
                for _, pl in ipairs(Players:GetPlayers()) do
                    if pl ~= lp then
                        local key = "player_" .. pl.UserId
                        tracked[key] = true
                        updateESP(pl, key, false)
                    end
                end
            end
            if ESPNPCEnabled then
                local enemiesFolder = workspace:FindFirstChild("Enemies")
                if enemiesFolder then
                    for _, npc in ipairs(enemiesFolder:GetChildren()) do
                        if npc:IsA("Model") then
                            local key = "npc_" .. npc.Name .. tostring(npc)
                            tracked[key] = true
                            updateESP(npc, key, true)
                        end
                    end
                end
            end
            for key, _ in pairs(espObjects) do
                if not tracked[key] then removeDrawings(key) end
            end
        end)
    end

    local function stopESP()
        if espConnection then espConnection:Disconnect() espConnection = nil end
        for key, _ in pairs(espObjects) do removeDrawings(key) end
    end

    return {
        setEnabled = function(v)
            ESPEnabled = v
            if ESPEnabled or ESPNPCEnabled then startESP() else stopESP() end
        end,
        setNPCEnabled = function(v)
            ESPNPCEnabled = v
            if ESPEnabled or ESPNPCEnabled then startESP() else stopESP() end
        end,
        setBox = function(v) ESPBox = v end,
        setCornerBox = function(v) ESPCornerBox = v end,
        setFilledBox = function(v) ESPFilledBox = v end,
        setLines = function(v) ESPLines = v end,
        setName = function(v) ESPName = v end,
        setDistance = function(v) ESPDistance = v end,
        setHealthBar = function(v) ESPHealthBar = v end,
        setHealthNum = function(v) ESPHealthNum = v end,
        setWeapon = function(v) ESPWeapon = v end,
        setTeam = function(v) ESPTeam = v end,
        setBounty = function(v) ESPBounty = v end,
        setSkeleton = function(v) ESPSkeleton = v end,
        setHeadDot = function(v) ESPHeadDot = v end,
        setOffScreen = function(v) ESPOffScreen = v end,
        setChams = function(v) ESPChams = v end,
        setNPCBox = function(v) ESPNPCBox = v end,
        setNPCName = function(v) ESPNPCName = v end,
        setNPCDist = function(v) ESPNPCDist = v end,
        setNPCHp = function(v) ESPNPCHp = v end,
        setNPCChams = function(v) ESPNPCChams = v end
    }
end)()

-- ================================================
--  PLAYER FEATURES (Fake Items, Movement, Misc)
-- ================================================
local PlayerFeatures = (function()
    local fakeKorblox = false
    local fakeKorbloxVersion = "V1"
    local fakeHeadless = false
    local fakeHeadlessVersion = "V1"
    local stretched = false
    local stretchAmount = 0.65
    local jumpBoost = false
    local jumpPower = 100
    local speedHack = false
    local speedValue = 50
    local flyEnabled = false
    local flySpeed = 50
    local flySpin = false
    local flySpinSpeed = 50
    local infiniteJump = false
    local autoKen = false

    local stretchConn = nil
    local speedConn = nil
    local flyConn = nil
    local flySpinConn = nil
    local flyMiniGui = nil
    local flySpinMiniGui = nil
    local flyActive = false
    local flySpinActive = false
    local _flyUp = false
    local _flyDown = false

    -- Fake Items
    local korbloxMeshes = {}
    local hiddenHairAcc = {}

    local function applyFakeKorblox()
