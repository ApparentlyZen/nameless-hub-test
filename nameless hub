-- =====================================================================
local FlyExploit = (function()
    local M = {}
    
    local lp = Players.LocalPlayer
    local runService = RunService
    local uis = UserInputService
    local ts = game:GetService("TweenService")
    
    local settings = {
        flyActive = false,
        noclipActive = false,
        mode = "CFrame",
        speed = 50,
        incore = nil,
        nocore = nil
    }
    
    local function StopFly()
        settings.flyActive = false
        if settings.incore then settings.incore:Disconnect() end
        if lp.Character and lp.Character:FindFirstChild("Humanoid") then
            lp.Character.Humanoid.PlatformStand = false
            lp.Character.Humanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
        end
    end
    
    local function StartFly()
        StopFly(); settings.flyActive = true
        local char = lp.Character; if not char then return end
        local hrp = char:FindFirstChild("HumanoidRootPart"); local hum = char:FindFirstChild("Humanoid")
        
        settings.incore = runService.Stepped:Connect(function()
            if not settings.flyActive or not hrp.Parent then StopFly() return end
            local moveDir = hum.MoveDirection
            
            if settings.mode == "CFrame" then
                hum.PlatformStand = true
                hrp.CFrame = hrp.CFrame + (moveDir * settings.speed/10)
                hrp.Velocity = Vector3.zero
            elseif settings.mode == "Velocity" then
                hrp.Velocity = (moveDir * settings.speed) + Vector3.new(0, 2, 0)
            elseif settings.mode == "Swim" then
                hum:ChangeState(Enum.HumanoidStateType.Swimming)
                hrp.Velocity = moveDir * settings.speed
            elseif settings.mode == "TP-Fast" then
                if moveDir.Magnitude > 0 then hrp.CFrame = hrp.CFrame * CFrame.new(0, 0, -settings.speed/5) end
            elseif settings.mode == "Float" then
                hrp.Velocity = Vector3.new(moveDir.X * settings.speed, 1.5, moveDir.Z * settings.speed)
            elseif settings.mode == "Tween" then
                if moveDir.Magnitude > 0 then ts:Create(hrp, TweenInfo.new(0.1, Enum.EasingStyle.Linear), {CFrame = hrp.CFrame + (moveDir * settings.speed/5)}):Play() end
            end
            
            if uis:IsKeyDown(Enum.KeyCode.Space) then hrp.CFrame = hrp.CFrame * CFrame.new(0, settings.speed/15, 0) end
            if uis:IsKeyDown(Enum.KeyCode.LeftShift) then hrp.CFrame = hrp.CFrame * CFrame.new(0, -settings.speed/15, 0) end
        end)
    end
    
    local function ToggleNoClip(state)
        settings.noclipActive = state
        if settings.nocore then settings.nocore:Disconnect() end
        if state then
            settings.nocore = runService.Stepped:Connect(function()
                if not settings.noclipActive then settings.nocore:Disconnect() return end
                if lp.Character then
                    for _, part in pairs(lp.Character:GetDescendants()) do
                        if part:IsA("BasePart") then part.CanCollide = false end
                    end
                end
            end)
        end
    end
    
    function M:SetMode(mode)
        settings.mode = mode
    end
    
    function M:SetSpeed(speed)
        settings.speed = speed
    end
    
    function M:ToggleFly(state)
        if state then StartFly() else StopFly() end
    end
    
    function M:ToggleNoClip(state)
        ToggleNoClip(state)
    end
    
    return M
end)()

