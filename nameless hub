    if not topOn and not botOn then return nil end
    local h = math.abs(topScreen.Y - botScreen.Y) local w = h * 0.6
    return { top=topScreen, bot=botScreen, cx=topScreen.X, w=w, h=h, depth=topZ, onScreen=topOn or botOn }
