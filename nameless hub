-- Silent Aim Players
function SilentAimModule:SetPlayerSilentAim(state)
    UserWantsPlayerAim      = state
    SilentAimPlayersEnabled = state
    ZSkillsEnabled          = state  -- ZSkill auto-suit le silent aim
    if state then
        startRenderLoop()
    else
        if not SilentAimNPCsEnabled then stopRenderLoop() end
        stopAimlock()
    end
end

-- Silent Aim NPCs
function SilentAimModule:SetNPCSilentAim(state)
    UserWantsNPCAim      = state
    SilentAimNPCsEnabled = state
    if state then
        startRenderLoop()
    else
        if not SilentAimPlayersEnabled then stopRenderLoop() end
    end
end

-- Prediction
function SilentAimModule:SetPrediction(state) PredictionEnabled = state end
function SilentAimModule:SetPredictionAmount(n) if type(n) == "number" then PredictionAmount = n end end

-- Distance
function SilentAimModule:SetDistanceLimit(n) if type(n) == "number" then maxRange = n end end

-- Highlight
function SilentAimModule:SetHighlight(state)
    HighlightEnabled = state
    if not state then clearHighlight() end
end
function SilentAimModule:IsHighlightEnabled() return HighlightEnabled end

-- Z/M1 Skills mode
function SilentAimModule:SetZSkillorM1(state) ZSkillorM1 = state end

-- Auto Ken
function SilentAimModule:SetAutoKen(state)
    AutoKen = state
    if state then startAutoKenLoop() end
end

-- Selected player
function SilentAimModule:SetSelectedPlayer(name)
    if not name or name == "" then Selectedplayer = nil return end
    local f = Players:FindFirstChild(name)
    if f then Selectedplayer = f end
end
function SilentAimModule:GetSelectedPlayer()
    return Selectedplayer and Selectedplayer.Name or "None"
end

-- Target Info UI
function SilentAimModule:SetInfo(state)
    TargetInfo = state
    if state then
        if not uiInfoConn then
            uiInfoConn = RunService.RenderStepped:Connect(function()
                local target = getNearest(1000)
                if target and target:FindFirstChildOfClass("Humanoid") then
                    local hum = target:FindFirstChildOfClass("Humanoid")
                    targetNameLabel.Text = target.Name
                    hpFill.Size = UDim2.new(math.clamp(hum.Health / hum.MaxHealth, 0, 1), 0, 1, 0)
                    hpBg.Visible = true hpFill.Visible = true targetFrame.Visible = true
                else
                    targetNameLabel.Text = "No target"
                    hpBg.Visible = false hpFill.Visible = false targetFrame.Visible = true
                end
            end)
        end
    else
        if uiInfoConn then uiInfoConn:Disconnect() uiInfoConn = nil end
        targetFrame.Visible = false
    end
end

-- Pause / Restore (internal use / external)
function SilentAimModule:Pause()
    SilentAimPlayersEnabled = false
    SilentAimNPCsEnabled    = false
end
function SilentAimModule:Restore()
    SilentAimPlayersEnabled = UserWantsPlayerAim
    SilentAimNPCsEnabled    = UserWantsNPCAim
end

function SilentAimModule:IsPlayerAimEnabled() return SilentAimPlayersEnabled end
function SilentAimModule:IsNPCAimEnabled()    return SilentAimNPCsEnabled    end

-- Mini toggles
function SilentAimModule:SetMiniTogglePlayerSilentAim(state)
    if not MiniPlayerCreated and state then
        MiniPlayerState = { value = SilentAimPlayersEnabled }
        MiniPlayerGui   = createMiniToggle("Player", UDim2.new(0, 10, 0, 90), MiniPlayerState, function(v)
            MiniPlayerState.value = v
            UpdateMiniState()
        end)
        MiniPlayerCreated = true
    elseif MiniPlayerCreated and MiniPlayerGui then
        MiniPlayerGui.Enabled = state
    end
end

function SilentAimModule:SetMiniToggleNpcSilentAim(state)
    if not MiniNpcCreated and state then
        MiniNpcState = { value = SilentAimNPCsEnabled }
        MiniNpcGui   = createMiniToggle("NPC", UDim2.new(0, 10, 0, 50), MiniNpcState, function(v)
            MiniNpcState.value = v
            UpdateMiniState()
        end)
        MiniNpcCreated = true
    elseif MiniNpcCreated and MiniNpcGui then
        MiniNpcGui.Enabled = state
    end
end

return SilentAimModule
