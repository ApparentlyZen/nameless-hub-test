local PagePlayer = Window:Page({ Name = "Player", Icon = "81598136527047" })

-- seulement Infinite Jump + Jump Power
local SecChar = PagePlayer:Section({ Name = "Character", Side = 1, Icon = "81598136527047" })

SecChar:Toggle({
    Name="Infinite Jump", Flag="InfJump", Default=false,
    Callback=function(v)
        if v then
            game:GetService("UserInputService").JumpRequest:Connect(function()
                if not Library.Flags["InfJump"] then return end
                local char = lp.Character
                local hum  = char and char:FindFirstChildOfClass("Humanoid")
                if hum then hum:ChangeState(Enum.HumanoidStateType.Jumping) end
            end)
        end
    end
})

SecChar:Slider({
    Name="Jump Power", Flag="JumpPower", Min=7, Max=500, Default=7, Decimals=1, Suffix="",
    Callback=function(v)
        local char = lp.Character
        local hum  = char and char:FindFirstChildOfClass("Humanoid")
        if hum then hum.JumpPower = v end
    end
})

