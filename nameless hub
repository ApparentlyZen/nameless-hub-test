local saPlayerNames = {"None"}
for _, pl in ipairs(Players:GetPlayers()) do if pl ~= player then table.insert(saPlayerNames, pl.Name) end end
local saPlayerDrop = SecSA:Dropdown({ Name="Lock On Player", Flag="SALock", Items=saPlayerNames, Default="None",
    Callback=function(v) SA:SetSelectedPlayer(v=="None" and nil or v) end })
local function RefreshSAPlayers()
    local list = {"None"}
    for _, pl in ipairs(Players:GetPlayers()) do if pl ~= player then table.insert(list, pl.Name) end end
    saPlayerDrop:Refresh(list)
end
Players.PlayerAdded:Connect(RefreshSAPlayers)
Players.PlayerRemoving:Connect(RefreshSAPlayers)

