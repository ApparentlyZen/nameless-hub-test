    d.name.Size = 13 d.dist.Color = Color3.fromRGB(200,200,200) d.hpNum.Color = Color3.fromRGB(255,255,255)
    d.weapon.Color = Color3.fromRGB(255,220,100) d.team.Color = Color3.fromRGB(100,200,255) d.bounty.Color = Color3.fromRGB(255,180,50)
    d.headDot.Radius = 4 d.headDot.Thickness = 1 d.headDot.Filled = true d.filled.Transparency = 0.7 d.arrow.Thickness = 1 d.arrow.Filled = true
    espObjects[key] = d return d
end

local function hideDrawings(d)
    if not d then return end
    for _, obj in pairs(d) do if type(obj) ~= "table" then obj.Visible = false end end
    if d.sk then for _, s in ipairs(d.sk) do s.Visible = false end end
end

local function removeDrawings(key)
    local d = espObjects[key] if not d then return end
    for _, obj in pairs(d) do if type(obj) ~= "table" then pcall(function() obj:Remove() end) elseif type(obj) == "table" then for _, s in ipairs(obj) do pcall(function() s:Remove() end) end end end
    espObjects[key] = nil
end

local function applyChams(char, col)
    if not char then return end local key = tostring(char) if chamsObjects[key] then return end chamsObjects[key] = {}
    for _, part in ipairs(char:GetDescendants()) do if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
        local orig = part.Color part.Color = col table.insert(chamsObjects[key], {part=part, orig=orig}) end end
end

local function removeChams(char)
    if not char then return end local key = tostring(char) if not chamsObjects[key] then return end
    for _, data in ipairs(chamsObjects[key]) do pcall(function() data.part.Color = data.orig end) end chamsObjects[key] = nil
end

local function updateESP(target, key, isNPC)
    local char = isNPC and target or target.Character if not char then hideDrawings(espObjects[key]) return end
    local hrp = char:FindFirstChild("HumanoidRootPart") local hum = char:FindFirstChildOfClass("Humanoid")
    if not hrp or not hum or hum.Health <= 0 then hideDrawings(espObjects[key]) return end
    local cam = workspace.CurrentCamera if not cam then return end
    local bounds = getCharBounds(char) local d = espObjects[key] or createDrawings(key)
    local col = Color3.fromRGB(255, 50, 50)
    if not isNPC then local pl = Players:FindFirstChild(char.Name) if pl and not isESPEnemy(pl) then col = Color3.fromRGB(50, 255, 50) end
    else col = Color3.fromRGB(255, 165, 0) end
    local myHRP = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    local dist  = myHRP and math.floor((hrp.Position - myHRP.Position).Magnitude) or 0
    local screenPos2, onScreen2 = worldToViewport(hrp.Position)
    if not onScreen2 and ESPOffScreen then
        local sc  = Vector2.new(cam.ViewportSize.X / 2, cam.ViewportSize.Y / 2)
        local dir = (screenPos2 - sc).Unit local angle = math.atan2(dir.Y, dir.X)
        local ap  = sc + dir * 80 local sz = 10
        d.arrow.PointA = ap + Vector2.new(math.cos(angle) * sz, math.sin(angle) * sz)
        d.arrow.PointB = ap + Vector2.new(math.cos(angle + 2.4) * sz * 0.5, math.sin(angle + 2.4) * sz * 0.5)
        d.arrow.PointC = ap + Vector2.new(math.cos(angle - 2.4) * sz * 0.5, math.sin(angle - 2.4) * sz * 0.5)
        d.arrow.Color = col d.arrow.Visible = true
    else d.arrow.Visible = false end
    if not bounds or not bounds.onScreen then hideDrawings(espObjects[key]) return end
    local cx = bounds.cx local w2 = bounds.w / 2 local topY = bounds.top.Y local botY = bounds.bot.Y
    local left = cx - w2 local right = cx + w2 local cl = bounds.w * 0.25
    d.boxTop.From=Vector2.new(left,topY)   d.boxTop.To=Vector2.new(right,topY)
    d.boxBot.From=Vector2.new(left,botY)   d.boxBot.To=Vector2.new(right,botY)
    d.boxLeft.From=Vector2.new(left,topY)  d.boxLeft.To=Vector2.new(left,botY)
    d.boxRight.From=Vector2.new(right,topY) d.boxRight.To=Vector2.new(right,botY)
    for _, b in ipairs({d.boxTop,d.boxBot,d.boxLeft,d.boxRight}) do b.Color = col b.Visible = (isNPC and ESPNPCBox_v or ESPBox) end
    d.cTL1.From=Vector2.new(left,topY)   d.cTL1.To=Vector2.new(left+cl,topY)
    d.cTL2.From=Vector2.new(left,topY)   d.cTL2.To=Vector2.new(left,topY+cl)
    d.cTR1.From=Vector2.new(right,topY)  d.cTR1.To=Vector2.new(right-cl,topY)
    d.cTR2.From=Vector2.new(right,topY)  d.cTR2.To=Vector2.new(right,topY+cl)
    d.cBL1.From=Vector2.new(left,botY)   d.cBL1.To=Vector2.new(left+cl,botY)
    d.cBL2.From=Vector2.new(left,botY)   d.cBL2.To=Vector2.new(left,botY-cl)
    d.cBR1.From=Vector2.new(right,botY)  d.cBR1.To=Vector2.new(right-cl,botY)
    d.cBR2.From=Vector2.new(right,botY)  d.cBR2.To=Vector2.new(right,botY-cl)
    for _, b in ipairs({d.cTL1,d.cTL2,d.cTR1,d.cTR2,d.cBL1,d.cBL2,d.cBR1,d.cBR2}) do b.Color = col b.Visible = ESPCornerBox end
    d.filled.Position=Vector2.new(left,topY) d.filled.Size=Vector2.new(bounds.w,bounds.h) d.filled.Color=col d.filled.Visible=ESPFilledBox
    d.line.From=Vector2.new(cam.ViewportSize.X/2,0) d.line.To=Vector2.new(cx,topY) d.line.Color=col d.line.Visible=ESPLines
    d.name.Text=char.Name d.name.Position=Vector2.new(cx,topY-16) d.name.Color=col d.name.Visible=(isNPC and ESPNPCName_v or ESPName)
    d.dist.Text=dist.."m" d.dist.Position=Vector2.new(cx,botY+2) d.dist.Visible=(isNPC and ESPNPCDist_v or ESPDistance)
    local hpRatio = math.clamp(hum.Health / hum.MaxHealth, 0, 1) local barX = left - 6
    local hpColor = Color3.fromRGB(math.floor(255 * (1 - hpRatio)), math.floor(255 * hpRatio), 0)
    d.hpBg.From=Vector2.new(barX,topY) d.hpBg.To=Vector2.new(barX,botY) d.hpBg.Color=Color3.fromRGB(40,40,40) d.hpBg.Visible=(isNPC and ESPNPCHp_v or ESPHealthBar)
    local fillY = botY - (botY - topY) * hpRatio
    d.hpFill.From=Vector2.new(barX,fillY) d.hpFill.To=Vector2.new(barX,botY) d.hpFill.Color=hpColor d.hpFill.Visible=(isNPC and ESPNPCHp_v or ESPHealthBar)
    d.hpNum.Text=math.floor(hum.Health).."/"..math.floor(hum.MaxHealth) d.hpNum.Position=Vector2.new(barX-2,topY+bounds.h/2-6) d.hpNum.Visible=ESPHealthNum
    local weaponStr = ""
    if ESPWeapon then for _, child in ipairs(char:GetChildren()) do if child:IsA("Tool") then weaponStr = child.Name break end end end
    d.weapon.Text=weaponStr d.weapon.Position=Vector2.new(cx,topY-28) d.weapon.Visible=ESPWeapon
    local teamStr = ""
    if not isNPC then local pl = Players:FindFirstChild(char.Name) teamStr = pl and pl.Team and pl.Team.Name or "" end
    d.team.Text=teamStr d.team.Position=Vector2.new(cx,botY+13) d.team.Visible=ESPTeam
    local bountyStr = ""
    if ESPBounty and not isNPC then
        local pl = Players:FindFirstChild(char.Name)
        if pl then local ls = pl:FindFirstChild("leaderstats") local b = ls and (ls:FindFirstChild("Bounty") or ls:FindFirstChild("Beli")) bountyStr = b and ("$" .. tostring(b.Value)) or "" end
    end
    d.bounty.Text=bountyStr d.bounty.Position=Vector2.new(cx,botY+24) d.bounty.Visible=ESPBounty
    local head = char:FindFirstChild("Head")
    if head and ESPHeadDot then local hs, ho = worldToViewport(head.Position) if ho then d.headDot.Position=hs d.headDot.Color=col d.headDot.Visible=true else d.headDot.Visible=false end
    else d.headDot.Visible=false end
    for i, bone in ipairs(skBones) do
        local p1 = char:FindFirstChild(bone[1]) local p2 = char:FindFirstChild(bone[2]) local s = d.sk[i]
        if p1 and p2 and ESPSkeleton then
            local sp1, on1 = worldToViewport(p1.Position) local sp2, on2 = worldToViewport(p2.Position)
            if on1 or on2 then s.From=sp1 s.To=sp2 s.Color=col s.Visible=true else s.Visible=false end
        else s.Visible=false end
    end
    if (isNPC and ESPNPCChams_v) or (not isNPC and ESPChams) then applyChams(char, col) else removeChams(char) end
end

local function startESP()
    if espConnection then return end
    espConnection = RunService.RenderStepped:Connect(function()
        local tracked = {}
        if ESPEnabled then
            for _, pl in ipairs(Players:GetPlayers()) do if pl ~= player then
                local key = "player_" .. pl.UserId tracked[key] = true updateESP(pl, key, false) end end
        end
        if ESPNPCEnabled then
            local ef = workspace:FindFirstChild("Enemies") if ef then
                for _, npc in ipairs(ef:GetChildren()) do if npc:IsA("Model") then
                    local key = "npc_" .. npc.Name .. tostring(npc) tracked[key] = true updateESP(npc, key, true) end end
            end
        end
        for key in pairs(espObjects) do if not tracked[key] then removeDrawings(key) end end
    end)
end

local function stopESP()
    if espConnection then espConnection:Disconnect() espConnection = nil end
    for key in pairs(espObjects) do removeDrawings(key) end
end

