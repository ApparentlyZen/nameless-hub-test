local flySettings = { flyActive=false, noclipActive=false, mode="CFrame", speed=50, incore=nil, nocore=nil }

local function StartFly()
    if flySettings.incore then flySettings.incore:Disconnect() end
    flySettings.flyActive = true
    flySettings.incore = RunService.Stepped:Connect(function()
        local char = player.Character
        local hrp  = char and char:FindFirstChild("HumanoidRootPart")
        local hum  = char and char:FindFirstChild("Humanoid")
        if not flySettings.flyActive or not hrp or not hum then return end
        
        local moveDir = hum.MoveDirection
        local verticalMove = (hum.Jump or UserInputService:IsKeyDown(Enum.KeyCode.Space)) and 1 or (UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) and -1 or 0)
        
        if flySettings.mode == "CFrame" then
            hum.PlatformStand = true
            hrp.CFrame = hrp.CFrame + (moveDir * flySettings.speed / 10) + Vector3.new(0, verticalMove * flySettings.speed / 15, 0)
            hrp.Velocity = Vector3.zero
        elseif flySettings.mode == "Velocity" then
            hrp.Velocity = (moveDir * flySettings.speed) + Vector3.new(0, verticalMove * flySettings.speed, 0)
        elseif flySettings.mode == "Swim" then
            hum:ChangeState(Enum.HumanoidStateType.Swimming) hrp.Velocity = moveDir * flySettings.speed
        elseif flySettings.mode == "TP-Fast" then
            if moveDir.Magnitude > 0 then hrp.CFrame = hrp.CFrame * CFrame.new(0, 0, -flySettings.speed / 5) end
        elseif flySettings.mode == "Float" then
            hrp.Velocity = Vector3.new(moveDir.X * flySettings.speed, verticalMove * flySettings.speed, moveDir.Z * flySettings.speed)
        elseif flySettings.mode == "Tween" then
            if moveDir.Magnitude > 0 then TweenService:Create(hrp, TweenInfo.new(0.1, Enum.EasingStyle.Linear), {CFrame = hrp.CFrame + (moveDir * flySettings.speed / 5)}):Play() end
        end
    end)
end

local function StopFly()
    flySettings.flyActive = false
    if flySettings.incore then flySettings.incore:Disconnect() flySettings.incore = nil end
    local char = player.Character
    if char then
        local hum = char:FindFirstChild("Humanoid")
        if hum then hum.PlatformStand = false hum:ChangeState(Enum.HumanoidStateType.GettingUp) end
    end
end

local function SetNoClip(v)
    flySettings.noclipActive = v
    if flySettings.nocore then flySettings.nocore:Disconnect() flySettings.nocore = nil end
    if v then
        flySettings.nocore = RunService.Stepped:Connect(function()
            if not flySettings.noclipActive then flySettings.nocore:Disconnect() return end
            local char = player.Character
            if char then for _, p in pairs(char:GetDescendants()) do if p:IsA("BasePart") then p.CanCollide = false end end end
        end)
    end
end

