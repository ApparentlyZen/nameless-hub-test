-- ================================================
--  HELPERS
-- ================================================
local function clearConnections()
    for _, c in ipairs(characterConnections) do pcall(function() c:Disconnect() end) end
    characterConnections = {}
    if dmgConn then pcall(function() dmgConn:Disconnect() end) dmgConn = nil end
    if aimRenderConn then pcall(function() aimRenderConn:Disconnect() end) aimRenderConn = nil end
    if aimTimeoutTask then pcall(function() task.cancel(aimTimeoutTask) end) aimTimeoutTask = nil end
end

local function getHRP(model)
    if not model then return nil end
    return model:FindFirstChild("HumanoidRootPart")
end

local function isAllyWithMe(tp)
    local g = player:FindFirstChild("PlayerGui")
    if not g then return false end
    local sf = g:FindFirstChild("Main") and g.Main:FindFirstChild("Allies")
        and g.Main.Allies:FindFirstChild("Container")
        and g.Main.Allies.Container:FindFirstChild("Allies")
        and g.Main.Allies.Container.Allies:FindFirstChild("ScrollingFrame")
    if sf then
        for _, f in pairs(sf:GetDescendants()) do
            if f:IsA("ImageButton") and f.Name == tp.Name then return true end
        end
    end
    return false
end

local function isEnemy(tp)
    if not tp or tp == player then return false end
    local mt, tt = player.Team, tp.Team
    if mt and tt then
        if mt.Name == "Pirates"  and tt.Name == "Marines" then return true end
        if mt.Name == "Marines"  and tt.Name == "Pirates"  then return true end
        if mt.Name == "Pirates"  and tt.Name == "Pirates"  then return not isAllyWithMe(tp) end
        if mt.Name == "Marines"  and tt.Name == "Marines"  then return false end
    end
    return true
end

local function getPredicted(hrp)
    if not hrp then return nil end
    local hum = hrp.Parent:FindFirstChildOfClass("Humanoid")
    if not PredictionEnabled or not hum or hum.WalkSpeed < 5 then return hrp.Position end
    return hrp.Position + (hrp.Velocity * PredictionAmount)
end

local function getClosestPlayer(lpHRP)
    if not lpHRP then return nil end
    local best, bestDist = nil, math.huge
    for _, pl in ipairs(Players:GetPlayers()) do
        if pl ~= player and isEnemy(pl) and pl.Character then
            local hum = pl.Character:FindFirstChildOfClass("Humanoid")
            local hrp = getHRP(pl.Character)
            if hum and hum.Health > 0 and hrp then
                local d = (hrp.Position - lpHRP.Position).Magnitude
                if d <= maxRange and d < bestDist then
                    bestDist = d
                    best = (Selectedplayer and Selectedplayer ~= pl) and best or pl
                    if not Selectedplayer then best = pl end
                end
            end
        end
    end
    if Selectedplayer then
        local hrp = Selectedplayer.Character and getHRP(Selectedplayer.Character)
        if hrp then return Selectedplayer end
    end
    return best
end

local function getClosestNPC(lpHRP)
    if not lpHRP then return nil end
    local ef = workspace:FindFirstChild("Enemies")
    if not ef then return nil end
    local best, bestDist = nil, math.huge
    for _, npc in ipairs(ef:GetChildren()) do
        if npc:IsA("Model") then
            local hum = npc:FindFirstChildOfClass("Humanoid")
            local hrp = getHRP(npc)
            if hum and hum.Health > 0 and hrp then
                local d = (hrp.Position - lpHRP.Position).Magnitude
                if d <= maxRange and d < bestDist then bestDist = d best = npc end
            end
        end
    end
    return best
end

-- ================================================
--  HIGHLIGHT
-- ================================================
local function clearHighlight()
    if currentHighlight then
        pcall(function() currentHighlight:Destroy() end)
        currentHighlight = nil
    end
    currentTargetType = nil
end

local function applyHighlight(model, ttype)
    if not HighlightEnabled or not model then return end
    if currentHighlight and currentHighlight.Adornee == model then return end
    clearHighlight()
    local h = Instance.new("Highlight")
    h.FillTransparency = 0.5
    h.OutlineTransparency = 0
    h.FillColor = ttype == "Player" and Color3.fromRGB(255, 50, 50) or Color3.fromRGB(255, 165, 0)
    h.OutlineColor = Color3.new(1, 1, 1)
    h.Adornee = model
    h.Parent = model
    currentHighlight = h
    currentTargetType = ttype
end

-- ================================================
--  RENDER LOOP (Silent Aim)
-- ================================================
local function stopRenderLoop()
    if renderConnection then
        pcall(function() renderConnection:Disconnect() end)
        renderConnection = nil
    end
    PlayersPosition = nil
    NPCPosition     = nil
    playersaimbot   = nil
    NPCaimbot       = nil
    clearHighlight()
end

local function startRenderLoop()
    if renderConnection then return end

    -- Hook mouse
    local Mouse = nil
    local ok, md = pcall(require, MouseMod)
    if ok and type(md) == "table" then
        Mouse = md
    else
        local char = player.Character or player.CharacterAdded:Wait()
        local root = char and char:FindFirstChild("HumanoidRootPart")
        if root then
            pcall(function()
                if type(Mouse) == "table" then
                    Mouse.Hit = CFrame.new(root.Position)
                    Mouse.Target = root
                end
            end)
        end
    end

    renderConnection = RunService.Heartbeat:Connect(function()
        if not SilentAimPlayersEnabled and not SilentAimNPCsEnabled then return end
        if not ZSkillorM1 then return end

        local char = player.Character
        local lpHRP = char and getHRP(char)
        if not lpHRP then return end

        -- Players
        if SilentAimPlayersEnabled then
            local target = getClosestPlayer(lpHRP)
            if target and target.Character then
                local hrp = getHRP(target.Character)
                if hrp then
                    PlayersPosition = getPredicted(hrp)
                    playersaimbot = target.Character
                    applyHighlight(target.Character, "Player")
                end
            else
                PlayersPosition = nil
                playersaimbot = nil
                if currentTargetType == "Player" then clearHighlight() end
            end
        else
            PlayersPosition = nil
            playersaimbot = nil
        end

        -- NPCs
        if SilentAimNPCsEnabled and not PlayersPosition then
            local npc = getClosestNPC(lpHRP)
            if npc then
                local hrp = getHRP(npc)
                if hrp then
                    NPCPosition = getPredicted(hrp)
                    NPCaimbot = npc
                    applyHighlight(npc, "NPC")
                end
            else
                NPCPosition = nil
                NPCaimbot = nil
                if currentTargetType == "NPC" then clearHighlight() end
            end
        else
            NPCPosition = nil
            NPCaimbot = nil
        end

        -- Apply to mouse
        local targetCFrame = PlayersPosition and CFrame.new(PlayersPosition)
            or NPCPosition and CFrame.new(NPCPosition)

        if targetCFrame and Mouse and type(Mouse) == "table" then
            pcall(function()
                Mouse.Hit    = targetCFrame
                Mouse.Target = nil
            end)
            if MouseMod then
                local ok2, md2 = pcall(require, MouseMod)
                if ok2 and type(md2) == "table" then
                    md2.Hit    = targetCFrame
                    md2.Target = nil
                end
            end
        end
    end)
end

-- ================================================
--  VSKILL — Disable/Enable Silent Aim temporarily
-- ================================================
local function pauseSilentAim()
    SilentAimPlayersEnabled = false
    SilentAimNPCsEnabled    = false
end

local function restoreSilentAim()
    SilentAimPlayersEnabled = UserWantsPlayerAim
    SilentAimNPCsEnabled    = UserWantsNPCAim
end

local function isVSkillActive()
    return (currentTool and currentTool.Name == "Shark Anchor" and sharkZActive)
        or (lastTool == "Dough-Dough" and vActive)
        or (currentTool and currentTool.Name == "Cursed Dual Katana" and cursedZActive)
end

-- ================================================
--  ZSKILL — Godhuman Z Camera Aimlock
-- ================================================
local function getNearest(maxDist)
    local char = player.Character
    local hrp  = char and getHRP(char)
    if not hrp then return nil end
    local best, bestDist = nil, maxDist or 1000
    for _, pl in ipairs(Players:GetPlayers()) do
        if pl ~= player and isEnemy(pl) and pl.Character and getHRP(pl.Character) then
            local ohp = getHRP(pl.Character)
            local hum = pl.Character:FindFirstChildOfClass("Humanoid")
            if ohp and hum and hum.Health > 0 then
                local d = (ohp.Position - hrp.Position).Magnitude
                if d < bestDist then bestDist = d best = pl.Character end
            end
        end
    end
    return best
end

local function stopAimlock()
    if not aimlockActive then return end
    aimlockActive    = false
    nearestZTarget   = nil
    godhumanZActive  = false
    if aimRenderConn then pcall(function() aimRenderConn:Disconnect() end) aimRenderConn = nil end
    if aimTimeoutTask then pcall(function() task.cancel(aimTimeoutTask) end) aimTimeoutTask = nil end
end

local function startAimlock()
    if not ZSkillsEnabled or aimlockActive then return end
    nearestZTarget = getNearest(1000)
    if not nearestZTarget then return end
    aimlockActive = true

    aimRenderConn = RunService.RenderStepped:Connect(function()
        if not ZSkillsEnabled then stopAimlock() return end
        if aimlockActive and nearestZTarget and getHRP(nearestZTarget) then
            camera.CFrame = CFrame.lookAt(camera.CFrame.Position, getHRP(nearestZTarget).Position)
        else
            stopAimlock()
        end
    end)

    aimTimeoutTask = task.delay(1, function()
        if aimlockActive then stopAimlock() end
    end)
end

