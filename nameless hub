local SecMob = PagePlayer:Section({ Name = "Mobility", Side = 2, Icon = "122669828593160" })

local FlyOn, FlyBody, FlyGyro, FlySpd = false, nil, nil, 100
SecMob:Toggle({
    Name = "Fly", Flag = "Fly", Default = false,
    Callback = function(v)
        FlyOn = v
        local char = lp.Character local root = char and char:FindFirstChild("HumanoidRootPart")
        if not root then return end
        if v then
            FlyBody = Instance.new("BodyVelocity")
            FlyBody.MaxForce = Vector3.new(1e5,1e5,1e5) FlyBody.Velocity = Vector3.zero FlyBody.Parent = root
            FlyGyro = Instance.new("BodyGyro")
            FlyGyro.MaxTorque = Vector3.new(1e5,1e5,1e5) FlyGyro.Parent = root
            task.spawn(function()
                local uis = game:GetService("UserInputService")
                while FlyOn do
                    task.wait()
                    local c = workspace.CurrentCamera local dir = Vector3.zero
                    if uis:IsKeyDown(Enum.KeyCode.W)            then dir += c.CFrame.LookVector  end
                    if uis:IsKeyDown(Enum.KeyCode.S)            then dir -= c.CFrame.LookVector  end
                    if uis:IsKeyDown(Enum.KeyCode.A)            then dir -= c.CFrame.RightVector end
                    if uis:IsKeyDown(Enum.KeyCode.D)            then dir += c.CFrame.RightVector end
                    if uis:IsKeyDown(Enum.KeyCode.Space)        then dir += Vector3.new(0,1,0) end
                    if uis:IsKeyDown(Enum.KeyCode.LeftControl)  then dir -= Vector3.new(0,1,0) end
                    if FlyBody then FlyBody.Velocity = dir * FlySpd end
                    if FlyGyro  then FlyGyro.CFrame  = c.CFrame     end
                end
                if FlyBody then FlyBody:Destroy() FlyBody = nil end
                if FlyGyro  then FlyGyro:Destroy()  FlyGyro = nil end
            end)
        end
    end
})

