            if flyActive then
                local char = lp.Character if not char then return end
                local hrp = char:FindFirstChild("HumanoidRootPart") if not hrp then return end
                local hum = char:FindFirstChildOfClass("Humanoid") if not hum then return end
                hum.PlatformStand = true
                flyAtt = Instance.new("Attachment", hrp)
                flyLV = Instance.new("LinearVelocity", hrp)
                flyLV.MaxForce = math.huge
                flyLV.VelocityConstraintMode = Enum.VelocityConstraintMode.Vector
                flyLV.VectorVelocity = Vector3.new(0, 0, 0)
                flyLV.Attachment0 = flyAtt
            else
                _flyUp = false _flyDown = false
                if flyLV then flyLV:Destroy() flyLV = nil end
                if flyAtt then flyAtt:Destroy() flyAtt = nil end
                local char = lp.Character if not char then return end
                local hum = char:FindFirstChildOfClass("Humanoid") if hum then hum.PlatformStand = false end
