-- ================================================
--  DAMAGE COUNTER WATCH
-- ================================================
local function watchDamageCounter()
    if dmgConn then pcall(function() dmgConn:Disconnect() end) dmgConn = nil end

    task.spawn(function()
        while true do
            local gui = player:FindFirstChild("PlayerGui") and
                        player.PlayerGui:FindFirstChild("Main")
            if not gui then task.wait(1) continue end

            local dc = gui:FindFirstChild("DmgCounter")
            if not dc then task.wait(1) continue end

            local lbl = dc:FindFirstChild("Text")
            if not lbl then task.wait(1) continue end

            dmgConn = lbl:GetPropertyChangedSignal("Text"):Connect(function()
                local dmg = tonumber(lbl.Text) or 0
                if dmg > 0 then
                    -- VSkill: pause if skill active + touching right
                    if isVSkillActive() and rightVTouching then
                        pauseSilentAim()
                    end
                    -- ZSkill: stop aimlock if damage
                    if aimlockActive then stopAimlock() end
                elseif not rightVTouching then
                    restoreSilentAim()
                end
            end)
            table.insert(characterConnections, dmgConn)
            break
        end
    end)
end

-- ================================================
--  TOUCH INPUT (VSkill + ZSkill merged)
-- ================================================
UserInputService.TouchStarted:Connect(function(touch)
    if not camera then return end
    if touch.Position.X > camera.ViewportSize.X / 2 then
        rightVTouching = true
        rightZTouching = true
        if isVSkillActive() then pauseSilentAim() end
    end
end)

UserInputService.TouchEnded:Connect(function(touch)
    if not camera then return end
    if touch.Position.X > camera.ViewportSize.X / 2 then
        rightVTouching = false
        rightZTouching = false
        restoreSilentAim()
        sharkZActive, vActive, cursedZActive = false, false, false

        -- ZSkill: trigger Godhuman Z aimlock on right touch release
        if currentTool and currentTool.Name == "Godhuman" and godhumanZActive then
            if not aimlockActive then startAimlock() end
        end
    end
end)

-- ================================================
--  TOOL HOOK
-- ================================================
local function hookTool(tool)
    if not tool then return end
    currentTool = tool
    lastTool    = tool.Name
    table.insert(characterConnections, tool.AncestryChanged:Connect(function(_, parent)
        if not parent then
            currentTool     = nil
            lastTool        = nil
            sharkZActive    = false
            vActive         = false
            cursedZActive   = false
            godhumanZActive = false
            rightVTouching  = false
            rightZTouching  = false
            aimlockActive   = false
            restoreSilentAim()
        end
    end))
end

-- ================================================
--  NAMECALL HOOK (VSkill + ZSkill merged, 1 hook)
-- ================================================
if not getgenv().NamelessSkillHooked then
    getgenv().NamelessSkillHooked = true
    local old
    old = hookmetamethod(game, "__namecall", function(self, ...)
        local method = getnamecallmethod()
        local args   = { ... }
        if method == "InvokeServer" or method == "FireServer" then
            local a1 = args[1]
            if typeof(a1) == "string" then
                local up = a1:upper()
                if up == "Z" and currentTool then
                    if currentTool.Name == "Godhuman"          then godhumanZActive = true end
                    if currentTool.Name == "Shark Anchor"      then sharkZActive    = true end
                    if currentTool.Name == "Cursed Dual Katana" then cursedZActive  = true end
                end
                if up == "V" and lastTool == "Dough-Dough" then
                    vActive = true
                end
            end
        end
        return old(self, ...)
    end)
end

-- ================================================
--  AUTO KEN
-- ================================================
local function startAutoKenLoop()
    if autoKenRunning then return end
    autoKenRunning = true
    task.spawn(function()
        while AutoKen do
            task.wait(0.1)
            if Services.CollectionService:HasTag(player.Character, "Ken") then
                local pg = player:FindFirstChild("PlayerGui")
                if pg then
                    local btn = pg:FindFirstChild("MobileContextButtons")
                        and pg.MobileContextButtons.ContextButtonFrame:FindFirstChild("BoundActionKen")
                    if btn and btn:GetAttribute("Selected") ~= true then
                        btn:SetAttribute("Selected", true)
                    end
                end
                local om = getrenv()._G.OM
                if om and not om.active then
                    om.radius = 0
                    om:setActive(true)
                    commE:FireServer("Ken", true)
                end
            end
        end
        autoKenRunning = false
    end)
end

-- ================================================
--  MINI TOGGLES
-- ================================================
local function createMiniToggle(name, position, stateRef, setter)
    local pg = player:WaitForChild("PlayerGui")
    if pg:FindFirstChild(name .. "NamelessMini") then
        pg[name .. "NamelessMini"]:Destroy()
    end
    local sg = Instance.new("ScreenGui")
    sg.Name = name .. "NamelessMini"
    sg.ResetOnSpawn = false
    sg.Parent = pg

    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, 70, 0, 40)
    btn.Position = position
    btn.TextScaled = true
    btn.TextWrapped = false
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    btn.BorderSizePixel = 0
    btn.Parent = sg

    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 8)

    local grad = Instance.new("UIGradient")
    grad.Rotation = 45
    grad.Parent = btn

    local function refresh(s)
        btn.Text = name .. (s and " ON" or " OFF")
        grad.Color = ColorSequence.new{
            ColorSequenceKeypoint.new(0, s and Color3.fromRGB(50, 200, 50) or Color3.fromRGB(255, 100, 50)),
            ColorSequenceKeypoint.new(1, s and Color3.fromRGB(50, 255, 50) or Color3.fromRGB(255, 200, 50))
        }
    end

    btn.MouseButton1Click:Connect(function()
        stateRef.value = not stateRef.value
        setter(stateRef.value)
        refresh(stateRef.value)
    end)

    -- Draggable
    local dragging, dragStart, startPos = false, nil, nil
    btn.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.Touch or i.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true dragStart = i.Position startPos = btn.Position
            i.Changed:Connect(function() if i.UserInputState == Enum.UserInputState.End then dragging = false end end)
        end
    end)
    btn.InputChanged:Connect(function(i)
        if dragging and (i.UserInputType == Enum.UserInputType.Touch or i.UserInputType == Enum.UserInputType.MouseMovement) then
            local d = i.Position - dragStart
            btn.Position = UDim2.new(0,
                math.clamp(startPos.X.Offset + d.X, 0, camera.ViewportSize.X - btn.AbsoluteSize.X),
                0,
                math.clamp(startPos.Y.Offset + d.Y, 0, camera.ViewportSize.Y - btn.AbsoluteSize.Y))
        end
    end)

    refresh(stateRef.value)
    return sg
end

local function UpdateMiniState()
    SilentAimPlayersEnabled = MiniPlayerState and MiniPlayerState.value or false
    SilentAimNPCsEnabled    = MiniNpcState    and MiniNpcState.value    or false
    UserWantsPlayerAim = SilentAimPlayersEnabled
    UserWantsNPCAim    = SilentAimNPCsEnabled
    if SilentAimPlayersEnabled or SilentAimNPCsEnabled then
        startRenderLoop()
    else
        stopRenderLoop()
        clearHighlight()
    end
end

-- ================================================
--  CHARACTER ADDED
-- ================================================
local function onCharacterAdded(char)
    clearConnections()
    sharkZActive = false vActive = false cursedZActive = false
    godhumanZActive = false aimlockActive = false
    rightVTouching = false rightZTouching = false
    restoreSilentAim()

    for _, c in ipairs(char:GetChildren()) do
        if c:IsA("Tool") then hookTool(c) end
    end
    table.insert(characterConnections, char.ChildAdded:Connect(function(c)
        if c:IsA("Tool") then hookTool(c) end
    end))
    table.insert(characterConnections, char.ChildRemoved:Connect(function(c)
        if c == currentTool then
            currentTool = nil lastTool = nil
            sharkZActive = false vActive = false cursedZActive = false
            godhumanZActive = false aimlockActive = false
            restoreSilentAim()
        end
    end))
    watchDamageCounter()
end

player.CharacterAdded:Connect(onCharacterAdded)
if player.Character then onCharacterAdded(player.Character) end

