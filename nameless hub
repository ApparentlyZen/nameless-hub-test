-- ================================================
--  SILENT AIM MODULE (intégré directement)
-- ================================================
local SA = (function()
    local SilentAimModule = {}

    local Players          = game:GetService("Players")
    local UserInputService = game:GetService("UserInputService")
    local RunService       = game:GetService("RunService")
    local RS               = game:GetService("ReplicatedStorage")

    local player   = Players.LocalPlayer
    local cam      = workspace.CurrentCamera
    local commE    = RS:WaitForChild("Remotes"):WaitForChild("CommE")
    local MouseMod = RS:FindFirstChild("Mouse")

    local Services = setmetatable({}, {
        __index = function(t, k)
            local ok, s = pcall(game.GetService, game, k)
            if ok then t[k] = s return s end
        end
    })

    -- STATE
    local SAPlayersEnabled  = false
    local SANPCsEnabled     = false
    local UserWantsPlayers  = false
    local UserWantsNPCs     = false
    local PredictionEnabled = false
    local HighlightEnabled  = false
    local AutoKen           = false
    local ZSkillorM1        = false
    local autoKenRunning    = false
    local maxRange          = 1000
    local PredAmount        = 0.1
    local Selectedplayer    = nil

    local renderConn        = nil
    local currentHighlight  = nil
    local currentTargetType = nil
    local PlayersPosition   = nil
    local NPCPosition       = nil

    local ZSkillsEnabled    = false
    local godhumanZActive   = false
    local aimlockActive     = false
    local nearestZTarget    = nil
    local aimRenderConn     = nil
    local aimTimeoutTask    = nil
    local TargetInfo        = false
    local uiInfoConn        = nil

    local currentTool   = nil
    local lastTool      = nil
    local sharkZActive  = false
    local vActive       = false
    local cursedZActive = false
    local rightTouching = false
    local dmgConn       = nil

    local charConns         = {}
    local MiniPlayerCreated = false
    local MiniNpcCreated    = false
    local MiniPlayerGui     = nil
    local MiniNpcGui        = nil
    local MiniPlayerState   = nil
    local MiniNpcState      = nil

    -- HELPERS
    local function clearConns()
        for _, c in ipairs(charConns) do pcall(function() c:Disconnect() end) end
        charConns = {}
        if dmgConn       then pcall(function() dmgConn:Disconnect() end)       dmgConn = nil end
        if aimRenderConn then pcall(function() aimRenderConn:Disconnect() end) aimRenderConn = nil end
        if aimTimeoutTask then pcall(function() task.cancel(aimTimeoutTask) end) aimTimeoutTask = nil end
    end

    local function getHRP(m) return m and m:FindFirstChild("HumanoidRootPart") end

    local function isAllyWithMe(tp)
        local g = player:FindFirstChild("PlayerGui") if not g then return false end
        local sf = g:FindFirstChild("Main") and g.Main:FindFirstChild("Allies")
            and g.Main.Allies:FindFirstChild("Container")
            and g.Main.Allies.Container:FindFirstChild("Allies")
            and g.Main.Allies.Container.Allies:FindFirstChild("ScrollingFrame")
        if sf then
            for _, f in pairs(sf:GetDescendants()) do
                if f:IsA("ImageButton") and f.Name == tp.Name then return true end
            end
        end
        return false
    end

    local function isEnemy(tp)
        if not tp or tp == player then return false end
        local mt, tt = player.Team, tp.Team
        if mt and tt then
            if mt.Name == "Pirates" and tt.Name == "Marines" then return true end
            if mt.Name == "Marines" and tt.Name == "Pirates" then return true end
            if mt.Name == "Pirates" and tt.Name == "Pirates" then return not isAllyWithMe(tp) end
            if mt.Name == "Marines" and tt.Name == "Marines" then return false end
        end
        return true
    end

    local function getPredicted(hrp)
        if not hrp then return nil end
        local hum = hrp.Parent:FindFirstChildOfClass("Humanoid")
        if not PredictionEnabled or not hum or hum.WalkSpeed < 5 then return hrp.Position end
        return hrp.Position + (hrp.Velocity * PredAmount)
    end

    local function getClosestPlayer(lpHRP)
        if not lpHRP then return nil end
        if Selectedplayer and Selectedplayer.Character and getHRP(Selectedplayer.Character) then
            return Selectedplayer
        end
        local best, bestDist = nil, math.huge
        for _, pl in ipairs(Players:GetPlayers()) do
            if pl ~= player and isEnemy(pl) and pl.Character then
                local hum = pl.Character:FindFirstChildOfClass("Humanoid")
                local hrp = getHRP(pl.Character)
                if hum and hum.Health > 0 and hrp then
                    local d = (hrp.Position - lpHRP.Position).Magnitude
                    if d <= maxRange and d < bestDist then bestDist = d best = pl end
                end
            end
        end
        return best
    end

    local function getClosestNPC(lpHRP)
        if not lpHRP then return nil end
        local ef = workspace:FindFirstChild("Enemies") if not ef then return nil end
        local best, bestDist = nil, math.huge
        for _, npc in ipairs(ef:GetChildren()) do
            if npc:IsA("Model") then
                local hum = npc:FindFirstChildOfClass("Humanoid")
                local hrp = getHRP(npc)
                if hum and hum.Health > 0 and hrp then
                    local d = (hrp.Position - lpHRP.Position).Magnitude
                    if d <= maxRange and d < bestDist then bestDist = d best = npc end
                end
            end
        end
        return best
    end

    -- HIGHLIGHT
    local function clearHighlight()
        if currentHighlight then pcall(function() currentHighlight:Destroy() end) currentHighlight = nil end
        currentTargetType = nil
    end

    local function applyHighlight(model, ttype)
        if not HighlightEnabled or not model then return end
        if currentHighlight and currentHighlight.Adornee == model then return end
        clearHighlight()
        local h = Instance.new("Highlight")
        h.FillTransparency    = 0.5
        h.OutlineTransparency = 0
        h.FillColor    = ttype == "Player" and Color3.fromRGB(255,50,50) or Color3.fromRGB(255,165,0)
        h.OutlineColor = Color3.new(1,1,1)
        h.Adornee = model h.Parent = model
        currentHighlight = h currentTargetType = ttype
    end

    -- RENDER LOOP
    local function stopRenderLoop()
        if renderConn then pcall(function() renderConn:Disconnect() end) renderConn = nil end
        PlayersPosition = nil NPCPosition = nil
        clearHighlight()
    end

    local function startRenderLoop()
        if renderConn then return end
        renderConn = RunService.Heartbeat:Connect(function()
            if not SAPlayersEnabled and not SANPCsEnabled then return end
            if not ZSkillorM1 then return end
            local char  = player.Character
            local lpHRP = char and getHRP(char) if not lpHRP then return end

            if SAPlayersEnabled then
                local target = getClosestPlayer(lpHRP)
                if target and target.Character then
                    local hrp = getHRP(target.Character)
                    if hrp then
                        PlayersPosition = getPredicted(hrp)
                        applyHighlight(target.Character, "Player")
                    end
                else
                    PlayersPosition = nil
                    if currentTargetType == "Player" then clearHighlight() end
                end
            else PlayersPosition = nil end

            if SANPCsEnabled and not PlayersPosition then
                local npc = getClosestNPC(lpHRP)
                if npc then
                    local hrp = getHRP(npc)
                    if hrp then NPCPosition = getPredicted(hrp) applyHighlight(npc, "NPC") end
                else
                    NPCPosition = nil
                    if currentTargetType == "NPC" then clearHighlight() end
                end
            else NPCPosition = nil end

            local tgt = PlayersPosition and CFrame.new(PlayersPosition)
                     or NPCPosition     and CFrame.new(NPCPosition)
            if tgt and MouseMod then
                local ok, md = pcall(require, MouseMod)
                if ok and type(md) == "table" then md.Hit = tgt md.Target = nil end
            end
        end)
    end

    -- VSKILL pause/restore
    local function pauseSA()   SAPlayersEnabled = false SANPCsEnabled = false end
    local function restoreSA() SAPlayersEnabled = UserWantsPlayers SANPCsEnabled = UserWantsNPCs end

    local function isVSkillActive()
        return (currentTool and currentTool.Name == "Shark Anchor" and sharkZActive)
            or (lastTool == "Dough-Dough" and vActive)
            or (currentTool and currentTool.Name == "Cursed Dual Katana" and cursedZActive)
    end

    -- ZSKILL aimlock
    local function getNearest(d)
        local char = player.Character local hrp = char and getHRP(char) if not hrp then return nil end
        local best, bd = nil, d or 1000
        for _, pl in ipairs(Players:GetPlayers()) do
            if pl ~= player and isEnemy(pl) and pl.Character then
                local ohp = getHRP(pl.Character)
                local hum = pl.Character:FindFirstChildOfClass("Humanoid")
                if ohp and hum and hum.Health > 0 then
                    local dist = (ohp.Position - hrp.Position).Magnitude
                    if dist < bd then bd = dist best = pl.Character end
                end
            end
        end
        return best
    end

    local function stopAimlock()
        if not aimlockActive then return end
        aimlockActive = false nearestZTarget = nil godhumanZActive = false
        if aimRenderConn  then pcall(function() aimRenderConn:Disconnect() end)    aimRenderConn = nil end
        if aimTimeoutTask then pcall(function() task.cancel(aimTimeoutTask) end) aimTimeoutTask = nil end
    end

    local function startAimlock()
        if not ZSkillsEnabled or aimlockActive then return end
        nearestZTarget = getNearest(1000) if not nearestZTarget then return end
        aimlockActive = true
        aimRenderConn = RunService.RenderStepped:Connect(function()
            if not ZSkillsEnabled then stopAimlock() return end
            if aimlockActive and nearestZTarget and getHRP(nearestZTarget) then
                cam.CFrame = CFrame.lookAt(cam.CFrame.Position, getHRP(nearestZTarget).Position)
            else stopAimlock() end
        end)
        aimTimeoutTask = task.delay(1, function() if aimlockActive then stopAimlock() end end)
    end

    -- TARGET INFO UI
    local sg = Instance.new("ScreenGui")
    sg.Name = "NamelessTargetUI" sg.ResetOnSpawn = false sg.Parent = player:WaitForChild("PlayerGui")
    local tf = Instance.new("Frame")
    tf.Size = UDim2.new(0.25,0,0.08,0) tf.Position = UDim2.new(0.5,0,0.05,0)
    tf.AnchorPoint = Vector2.new(0.5,0) tf.BackgroundTransparency = 1 tf.Visible = false tf.Parent = sg
    local tnl = Instance.new("TextLabel")
    tnl.Size = UDim2.new(1,0,0.5,0) tnl.BackgroundTransparency = 1 tnl.TextScaled = true
    tnl.Font = Enum.Font.GothamBold tnl.TextColor3 = Color3.new(1,1,1) tnl.Parent = tf
    local hpbg = Instance.new("Frame")
    hpbg.Size = UDim2.new(1,0,0.35,0) hpbg.Position = UDim2.new(0,0,0.55,0)
    hpbg.BackgroundColor3 = Color3.fromRGB(40,40,40) hpbg.BorderSizePixel = 0 hpbg.Parent = tf
    local hpf = Instance.new("Frame")
    hpf.Size = UDim2.new(1,0,1,0) hpf.BackgroundColor3 = Color3.fromRGB(0,255,0)
    hpf.BorderSizePixel = 0 hpf.Parent = hpbg

    -- DAMAGE WATCH
    local function watchDMG()
        if dmgConn then pcall(function() dmgConn:Disconnect() end) dmgConn = nil end
        task.spawn(function()
            while true do
                local gui = player.PlayerGui:FindFirstChild("Main")
                if not gui then task.wait(1) continue end
                local dc = gui:FindFirstChild("DmgCounter")
                if not dc then task.wait(1) continue end
                local lbl = dc:FindFirstChild("Text")
                if not lbl then task.wait(1) continue end
                dmgConn = lbl:GetPropertyChangedSignal("Text"):Connect(function()
                    local dmg = tonumber(lbl.Text) or 0
                    if dmg > 0 then
                        if isVSkillActive() and rightTouching then pauseSA() end
                        if aimlockActive then stopAimlock() end
                    elseif not rightTouching then restoreSA() end
                end)
                table.insert(charConns, dmgConn) break
            end
        end)
    end

    -- TOUCH
    UserInputService.TouchStarted:Connect(function(t)
        if not cam then return end
        if t.Position.X > cam.ViewportSize.X / 2 then
            rightTouching = true
            if isVSkillActive() then pauseSA() end
        end
    end)

    UserInputService.TouchEnded:Connect(function(t)
        if not cam then return end
        if t.Position.X > cam.ViewportSize.X / 2 then
            rightTouching = false
            restoreSA()
            sharkZActive = false vActive = false cursedZActive = false
            if currentTool and currentTool.Name == "Godhuman" and godhumanZActive then
                if not aimlockActive then startAimlock() end
            end
        end
    end)

    -- TOOL HOOK
    local function hookTool(tool)
        if not tool then return end
        currentTool = tool lastTool = tool.Name
        table.insert(charConns, tool.AncestryChanged:Connect(function(_, parent)
            if not parent then
                currentTool = nil lastTool = nil
                sharkZActive = false vActive = false cursedZActive = false
                godhumanZActive = false aimlockActive = false
                rightTouching = false restoreSA()
            end
        end))
    end

    -- NAMECALL HOOK (1 seul pour tout)
    if not getgenv().NamelessSkillHooked then
        getgenv().NamelessSkillHooked = true
        local old
        old = hookmetamethod(game, "__namecall", function(self, ...)
            local method = getnamecallmethod()
            local args   = { ... }
            if method == "InvokeServer" or method == "FireServer" then
                local a1 = args[1]
                if typeof(a1) == "string" then
                    local up = a1:upper()
                    if up == "Z" and currentTool then
                        if currentTool.Name == "Godhuman"            then godhumanZActive = true end
                        if currentTool.Name == "Shark Anchor"        then sharkZActive    = true end
                        if currentTool.Name == "Cursed Dual Katana"  then cursedZActive   = true end
                    end
                    if up == "V" and lastTool == "Dough-Dough" then vActive = true end
                end
            end
            return old(self, ...)
        end)
    end

    -- AUTO KEN
    local function startAutoKen()
        if autoKenRunning then return end autoKenRunning = true
        task.spawn(function()
            while AutoKen do
                task.wait(0.1)
                if player.Character and Services.CollectionService:HasTag(player.Character, "Ken") then
                    local pg = player:FindFirstChild("PlayerGui")
                    if pg then
                        local btn = pg:FindFirstChild("MobileContextButtons")
                            and pg.MobileContextButtons.ContextButtonFrame:FindFirstChild("BoundActionKen")
                        if btn and btn:GetAttribute("Selected") ~= true then btn:SetAttribute("Selected", true) end
                    end
                    local om = getrenv()._G.OM
                    if om and not om.active then om.radius = 0 om:setActive(true) commE:FireServer("Ken", true) end
                end
            end
            autoKenRunning = false
        end)
    end

    -- MINI TOGGLES
    local function createMini(name, pos, stateRef, setter)
        local pg = player:WaitForChild("PlayerGui")
        if pg:FindFirstChild(name.."NML") then pg[name.."NML"]:Destroy() end
        local sg2 = Instance.new("ScreenGui") sg2.Name = name.."NML" sg2.ResetOnSpawn = false sg2.Parent = pg
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(0,70,0,40) btn.Position = pos btn.TextScaled = true
        btn.TextColor3 = Color3.new(1,1,1) btn.BackgroundColor3 = Color3.fromRGB(30,30,30)
        btn.BorderSizePixel = 0 btn.Parent = sg2
        Instance.new("UICorner", btn).CornerRadius = UDim.new(0,8)
        local grad = Instance.new("UIGradient") grad.Rotation = 45 grad.Parent = btn
        local function refresh(s)
            btn.Text = name..(s and " ON" or " OFF")
            grad.Color = ColorSequence.new{
                ColorSequenceKeypoint.new(0, s and Color3.fromRGB(50,200,50) or Color3.fromRGB(255,100,50)),
                ColorSequenceKeypoint.new(1, s and Color3.fromRGB(50,255,50) or Color3.fromRGB(255,200,50))
            }
        end
        btn.MouseButton1Click:Connect(function()
            stateRef.value = not stateRef.value setter(stateRef.value) refresh(stateRef.value)
        end)
        local drag, ds, sp = false, nil, nil
        btn.InputBegan:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.Touch or i.UserInputType == Enum.UserInputType.MouseButton1 then
                drag = true ds = i.Position sp = btn.Position
                i.Changed:Connect(function() if i.UserInputState == Enum.UserInputState.End then drag = false end end)
            end
        end)
        btn.InputChanged:Connect(function(i)
            if drag and (i.UserInputType == Enum.UserInputType.Touch or i.UserInputType == Enum.UserInputType.MouseMovement) then
                local d = i.Position - ds
                btn.Position = UDim2.new(0,
                    math.clamp(sp.X.Offset+d.X, 0, cam.ViewportSize.X - btn.AbsoluteSize.X),
                    0,
                    math.clamp(sp.Y.Offset+d.Y, 0, cam.ViewportSize.Y - btn.AbsoluteSize.Y))
            end
        end)
        refresh(stateRef.value) return sg2
    end

    local function updateMini()
        SAPlayersEnabled = MiniPlayerState and MiniPlayerState.value or false
        SANPCsEnabled    = MiniNpcState    and MiniNpcState.value    or false
        UserWantsPlayers = SAPlayersEnabled UserWantsNPCs = SANPCsEnabled
        if SAPlayersEnabled or SANPCsEnabled then startRenderLoop() else stopRenderLoop() clearHighlight() end
    end

    -- CHARACTER ADDED
    local function onCharAdded(char)
        clearConns()
        sharkZActive = false vActive = false cursedZActive = false
        godhumanZActive = false aimlockActive = false rightTouching = false
        restoreSA()
        for _, c in ipairs(char:GetChildren()) do if c:IsA("Tool") then hookTool(c) end end
        table.insert(charConns, char.ChildAdded:Connect(function(c)
            if c:IsA("Tool") then hookTool(c) end
        end))
        table.insert(charConns, char.ChildRemoved:Connect(function(c)
            if c == currentTool then
                currentTool = nil lastTool = nil
                sharkZActive = false vActive = false cursedZActive = false
                godhumanZActive = false aimlockActive = false restoreSA()
            end
        end))
        watchDMG()
    end

    player.CharacterAdded:Connect(onCharAdded)
    if player.Character then onCharAdded(player.Character) end

    -- PUBLIC API
    function SilentAimModule:SetPlayerSilentAim(state)
        UserWantsPlayers = state SAPlayersEnabled = state ZSkillsEnabled = state
        if state then startRenderLoop() else if not SANPCsEnabled then stopRenderLoop() end stopAimlock() end
    end
    function SilentAimModule:SetNPCSilentAim(state)
        UserWantsNPCs = state SANPCsEnabled = state
        if state then startRenderLoop() else if not SAPlayersEnabled then stopRenderLoop() end end
    end
    function SilentAimModule:SetPrediction(state)      PredictionEnabled = state end
    function SilentAimModule:SetPredictionAmount(n)    if type(n)=="number" then PredAmount = n end end
    function SilentAimModule:SetDistanceLimit(n)       if type(n)=="number" then maxRange = n end end
    function SilentAimModule:SetHighlight(state)       HighlightEnabled = state if not state then clearHighlight() end end
    function SilentAimModule:SetZSkillorM1(state)      ZSkillorM1 = state end
    function SilentAimModule:SetAutoKen(state)         AutoKen = state if state then startAutoKen() end end
    function SilentAimModule:SetSelectedPlayer(name)
        if not name or name == "" then Selectedplayer = nil return end
        local f = Players:FindFirstChild(name) if f then Selectedplayer = f end
    end
    function SilentAimModule:SetInfo(state)
        TargetInfo = state
        if state then
            if not uiInfoConn then
                uiInfoConn = RunService.RenderStepped:Connect(function()
                    local t = getNearest(1000)
                    if t and t:FindFirstChildOfClass("Humanoid") then
                        local h = t:FindFirstChildOfClass("Humanoid")
                        tnl.Text = t.Name
                        hpf.Size = UDim2.new(math.clamp(h.Health/h.MaxHealth,0,1),0,1,0)
                        hpbg.Visible = true hpf.Visible = true tf.Visible = true
                    else tnl.Text = "No target" hpbg.Visible = false hpf.Visible = false tf.Visible = true end
                end)
            end
        else
            if uiInfoConn then uiInfoConn:Disconnect() uiInfoConn = nil end
            tf.Visible = false
        end
    end
    function SilentAimModule:SetMiniTogglePlayerSilentAim(state)
        if not MiniPlayerCreated and state then
            MiniPlayerState = { value = SAPlayersEnabled }
            MiniPlayerGui = createMini("Player", UDim2.new(0,10,0,90), MiniPlayerState, function(v)
                MiniPlayerState.value = v updateMini()
            end)
            MiniPlayerCreated = true
        elseif MiniPlayerCreated and MiniPlayerGui then MiniPlayerGui.Enabled = state end
    end
    function SilentAimModule:SetMiniToggleNpcSilentAim(state)
        if not MiniNpcCreated and state then
            MiniNpcState = { value = SANPCsEnabled }
            MiniNpcGui = createMini("NPC", UDim2.new(0,10,0,50), MiniNpcState, function(v)
                MiniNpcState.value = v updateMini()
            end)
            MiniNpcCreated = true
        elseif MiniNpcCreated and MiniNpcGui then MiniNpcGui.Enabled = state end
    end

    return SilentAimModule
end)()

