local KA_Gun = (function()
    local M = {}
    local active, targetMode = false, "NPCs"
    local function getTarget()
        local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
        if not hrp then return nil end
        local target, dmin = nil, 400
        if targetMode == "NPCs" or targetMode == "Both" then
            local ef = workspace:FindFirstChild("Enemies")
            if ef then
                for _, n in pairs(ef:GetChildren()) do
                    local nhrp = n:FindFirstChild("HumanoidRootPart")
                    if nhrp then
                        local d = (nhrp.Position - hrp.Position).Magnitude
                        if d < dmin then dmin = d; target = nhrp end
                    end
                end
            end
        end
        if (targetMode == "Players" or targetMode == "Both") and not target then
            for _, p in pairs(Players:GetPlayers()) do
                if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                    local phrp = p.Character.HumanoidRootPart
                    local d = (phrp.Position - hrp.Position).Magnitude
                    if d < dmin then dmin = d; target = phrp end
                end
            end
        end
        return target
    end

    function M:SetTarget(v) targetMode = v end
    function M:Toggle(v)
        active = v
        if v then
            task.spawn(function()
                while active do
                    local tool = player.Character and player.Character:FindFirstChildOfClass("Tool")
                    -- Vérifie si l'item est un Gun via l'attribut ou le nom
                    if tool and (tool:GetAttribute("WeaponType") == "Gun" or tool.Name:lower():find("gun")) then
                        local remote = tool:FindFirstChild("RemoteEvent") or tool:FindFirstChild("LeftClickRemote")
                        if remote then
                            local t = getTarget()
                            -- Vise la cible ou tire au centre si aucune cible n'est proche
                            remote:FireServer(t and t.Position or Vector3.new(0, 0, 0), 1)
                        end
                    end
                    task.wait(0.1)
                end
            end)
        end
    end
    return M
end)()

