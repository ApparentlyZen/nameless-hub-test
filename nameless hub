        setStretched = function(v) stretched = v if v then applyStretched() else removeStretched() end end,
        setStretchAmount = function(v) stretchAmount = v/100 if stretched then applyStretched() end end,
        setJumpBoost = function(v) jumpBoost = v if v then applyJump() else resetJump() end end,
        setJumpPower = function(v) jumpPower = v if jumpBoost then applyJump() end end,
        setSpeedHack = function(v) speedHack = v if v then applySpeed() else resetSpeed() end end,
        setSpeedValue = function(v) speedValue = v if speedHack then applySpeed() end end,
        setFly = function(v) flyEnabled = v if v then startFly() else stopFly() end end,
        setFlySpeed = function(v) flySpeed = v end,
        setFlySpin = function(v) flySpin = v if v then startFlySpin() else stopFlySpin() end end,
        setFlySpinSpeed = function(v) flySpinSpeed = v end,
        setInfiniteJump = function(v) infiniteJump = v end,
        setAutoKen = function(v) autoKen = v if v then startAutoKen() end end
    }
end)()

