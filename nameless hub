            grad.Color = ColorSequence.new{
                ColorSequenceKeypoint.new(0, state and Color3.fromRGB(165,100,255) or Color3.fromRGB(80,80,80)),
                ColorSequenceKeypoint.new(1, state and Color3.fromRGB(200,50,255) or Color3.fromRGB(50,50,50)),
            }
        end
        btn.MouseButton1Click:Connect(function()
            flySpinActive = not flySpinActive
            updateBtn(flySpinActive)
        end)
        local dragging,dragStart,startPos = false,nil,nil
        btn.InputBegan:Connect(function(i)
            if i.UserInputType==Enum.UserInputType.Touch or i.UserInputType==Enum.UserInputType.MouseButton1 then
                dragging=true dragStart=i.Position startPos=btn.Position
                i.Changed:Connect(function() if i.UserInputState==Enum.UserInputState.End then dragging=false end end)
            end
        end)
        btn.InputChanged:Connect(function(i)
            if dragging and (i.UserInputType==Enum.UserInputType.Touch or i.UserInputType==Enum.UserInputType.MouseMovement) then
                local d=i.Position-dragStart
                local vp=cam.ViewportSize
                btn.Position=UDim2.new(0,math.clamp(startPos.X.Offset+d.X,0,vp.X-btn.AbsoluteSize.X),0,math.clamp(startPos.Y.Offset+d.Y,0,vp.Y-btn.AbsoluteSize.Y))
            end
        end)
        updateBtn(false)
        flySpinMiniGui = sg
    end

    local function startFlySpin()
        if not flySpinMiniGui then createFlySpinMiniToggle() end
        local angle = 0
        if flySpinConn then flySpinConn:Disconnect() end
        flySpinConn = RunService.Heartbeat:Connect(function()
            if not flySpin or not flySpinActive then return end
            local char = lp.Character if not char then return end
            local hrp = char:FindFirstChild("HumanoidRootPart") if not hrp then return end
            angle = angle + math.rad(flySpinSpeed / 10)
            hrp.CFrame = CFrame.new(hrp.Position) * CFrame.Angles(0, angle, 0)
        end)
    end

    local function stopFlySpin()
        if flySpinConn then flySpinConn:Disconnect() flySpinConn = nil end
        if flySpinMiniGui then flySpinMiniGui:Destroy() flySpinMiniGui = nil end
        flySpinActive = false
    end

    local function startAutoKen()
        task.spawn(function()
            while autoKen do
                task.wait(0.1)
                if lp.Character and game:GetService("CollectionService"):HasTag(lp.Character, "Ken") then
                    local pg = lp:FindFirstChild("PlayerGui")
                    if pg then
                        local btn = pg:FindFirstChild("MobileContextButtons")
                            and pg.MobileContextButtons.ContextButtonFrame:FindFirstChild("BoundActionKen")
                        if btn and btn:GetAttribute("Selected") ~= true then btn:SetAttribute("Selected", true) end
                    end
                    local om = getrenv()._G.OM
                    if om and not om.active then om.radius=0 om:setActive(true) if commE then commE:FireServer("Ken",true) end end
                end
            end
        end)
    end

