-- Combat (colonne 2)
local SecCombat = PageLegit:Section({ Name = "Combat", Side = 2, Icon = "131319188753430" })

SecCombat:Toggle({ Name = "Auto Ken", Flag = "AutoKen", Default = false, Callback = function(v) SA:SetAutoKen(v) end })

local AutoClickOn = false
SecCombat:Toggle({
    Name = "Auto Click Sword", Flag = "AutoClick", Default = false,
    Callback = function(v)
        AutoClickOn = v
        if v then task.spawn(function()
            while AutoClickOn do
                task.wait(0.05)
                local char = lp.Character
                local tool = char and char:FindFirstChildOfClass("Tool")
